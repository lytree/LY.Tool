<u:SplashWindow
    x:Class="LYBox.UrsaWindow.Views.MainSplashWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:u="https://irihi.tech/ursa"
    Title="{DynamicResource SPLASH_STARTING}"
    Width="520"
    Height="460"
    CanResize="False"
    Icon="/Assets/lybox.ico"
    WindowDecorations="None">
    <u:SplashWindow.Styles>
        <Style Selector="Border#Backdrop">
            <Setter Property="Opacity" Value="0" />
            <Style.Animations>
                <Animation Duration="0:0:0.7" FillMode="Forward">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="1" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <Style Selector="Border#HeroImagePanel">
            <Setter Property="Opacity" Value="0" />
            <Style.Animations>
                <Animation Duration="0:0:0.95" FillMode="Forward">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0" />
                        <Setter Property="RenderTransform" Value="translate(0, -14) scale(0.97)" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="1" />
                        <Setter Property="RenderTransform" Value="translate(0, 0) scale(1)" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <Style Selector="Grid#BrandContent">
            <Setter Property="Opacity" Value="0" />
            <Style.Animations>
                <Animation Duration="0:0:0.85" Delay="0:0:0.18" FillMode="Forward">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0" />
                        <Setter Property="RenderTransform" Value="translate(0, 16)" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="1" />
                        <Setter Property="RenderTransform" Value="translate(0, 0)" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <Style Selector="Border#HaloPulse">
            <Style.Animations>
                <Animation Duration="0:0:2" IterationCount="INFINITE" PlaybackDirection="Alternate">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0.28" />
                        <Setter Property="RenderTransform" Value="scale(0.94)" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="0.72" />
                        <Setter Property="RenderTransform" Value="scale(1.08)" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <Style Selector="Image#BrandLogo">
            <Style.Animations>
                <Animation Duration="0:0:2.4" IterationCount="INFINITE">
                    <KeyFrame Cue="0%">
                        <Setter Property="RenderTransform" Value="rotate(0deg)" />
                    </KeyFrame>
                    <KeyFrame Cue="50%">
                        <Setter Property="RenderTransform" Value="rotate(5deg)" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="RenderTransform" Value="rotate(0deg)" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </u:SplashWindow.Styles>

    <Grid>
        <Border
            Name="Backdrop"
            Margin="18"
            Padding="24"
            CornerRadius="8"
            Theme="{DynamicResource CardBorder}"
            BoxShadow="0 4 16 0 #22000000">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="14">
                <Border
                    Name="HeroImagePanel"
                    Grid.Row="0"
                    Height="150"
                    CornerRadius="8"
                    ClipToBounds="True"
                    Background="{DynamicResource FluentSubtleBrush}">
                    <Grid>
                        <Image Source="/Assets/jk-girl.jpg" Stretch="UniformToFill" Opacity="0.82" />
                        <Border Background="{DynamicResource SmokeFillColorDefaultBrush}" />
                        <TextBlock
                            Margin="16"
                            VerticalAlignment="Bottom"
                            Classes="FluentBody"
                            FontWeight="SemiBold"
                            Text="{DynamicResource WELCOME_IRIHI}"
                            Foreground="{DynamicResource FluentColorText0}" />
                    </Grid>
                </Border>

                <Grid
                    Name="BrandContent"
                    Grid.Row="1"
                    ColumnDefinitions="Auto,*"
                    RowDefinitions="Auto,Auto"
                    ColumnSpacing="14">
                    <Grid Grid.RowSpan="2" Width="82" Height="82" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Name="HaloPulse" Background="{DynamicResource FluentColorPrimary}" CornerRadius="41" Opacity="0.15" />
                        <Image
                            Name="BrandLogo"
                            Width="64"
                            Height="64"
                            Source="/Assets/lybox-logo-256.png"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Grid>

                    <TextBlock
                        Grid.Column="1"
                        VerticalAlignment="Bottom"
                        Classes="FluentLargeTitle"
                        Text="{DynamicResource SPLASH_TITLE}" />
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="1"
                        Classes="FluentBody"
                        Text="{DynamicResource SPLASH_SUBTITLE}" />
                </Grid>

                <StackPanel Grid.Row="2" Spacing="4">
                    <TextBlock HorizontalAlignment="Center" Classes="FluentBody" Text="{DynamicResource SPLASH_WELCOME}" TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Row="3" Spacing="8">
                    <ProgressBar IsIndeterminate="True" Height="5" CornerRadius="999" />
                    <TextBlock HorizontalAlignment="Center" Classes="FluentCaption" Text="{DynamicResource LOADING_MODULES}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</u:SplashWindow>
