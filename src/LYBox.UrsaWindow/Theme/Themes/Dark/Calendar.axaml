    <StaticResource x:Key="CalendarItemCalendarButtonForeground" ResourceKey="FluentColorText0" />
    <SolidColorBrush x:Key="CalendarItemCalendarButtonBorderBrush" Color="Transparent" />
    <StaticResource x:Key="CalendarItemCalendarButtonPointeroverBackground" ResourceKey="FluentColorFill1" />
    <StaticResource x:Key="CalendarItemCalendarButtonPressedBackground" ResourceKey="FluentColorFill2" />
    <StaticResource x:Key="CalendarItemCalendarButtonSelectedBackground" ResourceKey="FluentColorPrimary" />
    <StaticResource x:Key="CalendarItemCalendarButtonSelectedForeground" ResourceKey="FluentColorBackground3" />
    <StaticResource x:Key="CalendarItemCalendarButtonDisabledForeground" ResourceKey="FluentColorDisabledText" />
    <StaticResource x:Key="CalendarItemCalendarButtonBlackoutForeground" ResourceKey="FluentColorText3" />
