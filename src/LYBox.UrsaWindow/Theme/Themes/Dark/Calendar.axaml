    <SolidColorBrush x:Key="CalendarItemCalendarDayButtonBackground" Color="Transparent" />
    <SolidColorBrush x:Key="CalendarItemCalendarDayButtonBorderBrush" Color="Transparent" />
    <StaticResource x:Key="CalendarItemCalendarDayButtonPointeroverBackground" ResourceKey="FluentColorFill1" />
    <StaticResource x:Key="CalendarItemCalendarDayButtonPressedBackground" ResourceKey="FluentColorFill2" />
    <StaticResource x:Key="CalendarItemCalendarDayButtonSelectedBackground" ResourceKey="FluentColorPrimary" />
    <StaticResource x:Key="CalendarItemCalendarDayButtonSelectedForeground" ResourceKey="FluentColorBackground3" />
    <StaticResource x:Key="CalendarItemCalendarDayButtonTodayForeground" ResourceKey="FluentColorPrimary" />
    <StaticResource x:Key="CalendarItemCalendarDayButtonTodayBackground" ResourceKey="FluentColorFill0" />
    <StaticResource x:Key="CalendarItemCalendarDayButtonDisabledForeground" ResourceKey="FluentColorDisabledText" />
    <StaticResource x:Key="CalendarItemCalendarDayButtonBlackoutForeground" ResourceKey="FluentColorText3" />
    <StaticResource x:Key="CalendarItemCalendarDayButtonInactiveForeground" ResourceKey="FluentColorText2" />
