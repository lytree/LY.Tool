<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StaticResource x:Key="NotificationCardBoxShadows" ResourceKey="FluentShadowElevated" />
    <StaticResource x:Key="NotificationCardLightBackground" ResourceKey="FluentColorBackground0" />
    <StaticResource x:Key="NotificationCardLightInformationBorderBrush" ResourceKey="FluentColorPrimary" />
    <StaticResource x:Key="NotificationCardLightInformationBackground" ResourceKey="FluentColorPrimaryLight" />
    <StaticResource x:Key="NotificationCardLightSuccessBorderBrush" ResourceKey="FluentColorSuccess" />
    <StaticResource x:Key="NotificationCardLightSuccessBackground" ResourceKey="FluentColorSuccessLight" />
    <StaticResource x:Key="NotificationCardLightWarningBorderBrush" ResourceKey="FluentColorWarning" />
    <StaticResource x:Key="NotificationCardLightWarningBackground" ResourceKey="FluentColorWarningLight" />
    <StaticResource x:Key="NotificationCardLightErrorBorderBrush" ResourceKey="FluentColorDanger" />
    <StaticResource x:Key="NotificationCardLightErrorBackground" ResourceKey="FluentColorDangerLight" />
    <StaticResource x:Key="NotificationCardCloseButtonForeground" ResourceKey="FluentColorText1" />
</ResourceDictionary>