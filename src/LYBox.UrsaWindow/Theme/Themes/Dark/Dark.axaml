    <SolidColorBrush x:Key="FluentColorInformationLightPointerover" Opacity="0.3" Color="{StaticResource FluentBlue5Color}" />
    <SolidColorBrush x:Key="FluentColorInformationLightActive" Opacity="0.4" Color="{StaticResource FluentBlue5Color}" />
    <!--  Success  -->
