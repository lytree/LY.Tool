    <!-- Official Color=#E4E7F5 -->
    <SolidColorBrush x:Key="FluentColorWhite" Color="{StaticResource FluentWhiteColor}" />
    <SolidColorBrush x:Key="FluentColorBlack" Color="{StaticResource FluentBlackColor}" />
    <!--  Primary  -->
    <SolidColorBrush x:Key="FluentColorPrimary" Color="{StaticResource FluentBlue5Color}" />
    <SolidColorBrush x:Key="FluentColorPrimaryPointerover" Color="{StaticResource FluentBlue6Color}" />
    <SolidColorBrush x:Key="FluentColorPrimaryActive" Color="{StaticResource FluentBlue7Color}" />
    <SolidColorBrush x:Key="FluentColorPrimaryDisabled" Color="{StaticResource FluentBlue2Color}" />
    <SolidColorBrush x:Key="FluentColorPrimaryLight" Opacity="0.2" Color="{StaticResource FluentBlue5Color}" />
    <SolidColorBrush x:Key="FluentColorPrimaryLightPointerover" Opacity="0.3" Color="{StaticResource FluentBlue5Color}" />
    <SolidColorBrush x:Key="FluentColorPrimaryLightActive" Opacity="0.4" Color="{StaticResource FluentBlue5Color}" />
    <!--  Secondary  -->
