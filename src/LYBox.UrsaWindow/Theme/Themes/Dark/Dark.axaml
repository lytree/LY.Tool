    <SolidColorBrush x:Key="FluentColorAIPurpleActive" Color="{StaticResource FluentAIPurple7Color}" />
    <SolidColorBrush x:Key="FluentColorAIPurpleDisabled" Color="{StaticResource FluentAIPurple2Color}" />

    <!-- AI Background -->
    <LinearGradientBrush x:Key="FluentColorAIBackgroundBottom" StartPoint="69.35%,0%" EndPoint="30.65%,100%">
        <GradientStop Offset="0.0658" Color="#33FFE28A" />
        <GradientStop Offset="0.504" Color="#33E72DFF" />
        <GradientStop Offset="0.9423" Color="#330073FF" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="FluentColorAIBackgroundBottomPointerover" StartPoint="69.35%,0%" EndPoint="30.65%,100%">
        <GradientStop Offset="0.0658" Color="#4DFFE28A" />
        <GradientStop Offset="0.504" Color="#4DE72DFF" />
        <GradientStop Offset="0.9423" Color="#4D0073FF" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="FluentColorAIBackgroundBottomActive" StartPoint="69.35%,0%" EndPoint="30.65%,100%">
        <GradientStop Offset="0.0658" Color="#66FFE28A" />
        <GradientStop Offset="0.504" Color="#66E72DFF" />
        <GradientStop Offset="0.9423" Color="#660073FF" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="FluentColorAIBackgroundTop" StartPoint="69.35%,0%" EndPoint="30.65%,100%">
        <GradientStop Offset="0.0658" Color="#5C5338FF" />
        <GradientStop Offset="0.3288" Color="#37B030F0" />
        <GradientStop Offset="0.5917" Color="#1C9A00AE" />
        <GradientStop Offset="0.9423" Color="#00000000" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="FluentColorAIBackgroundTopPointerover" StartPoint="69.35%,0%" EndPoint="30.65%,100%">
        <GradientStop Offset="0.0658" Color="#8A5338FF" />
        <GradientStop Offset="0.3288" Color="#53B030F0" />
        <GradientStop Offset="0.5917" Color="#299A00AE" />
        <GradientStop Offset="0.9423" Color="#00000000" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="FluentColorAIBackgroundTopActive" StartPoint="69.35%,0%" EndPoint="30.65%,100%">
        <GradientStop Offset="0.0658" Color="#B85338FF" />
        <GradientStop Offset="0.3288" Color="#6EB030F0" />
        <GradientStop Offset="0.5917" Color="#379A00AE" />
        <GradientStop Offset="0.9423" Color="#00000000" />
    </LinearGradientBrush>

    <!--  Text and Icons  -->
    <SolidColorBrush x:Key="FluentColorText0" Color="{StaticResource FluentGrey9Color}" />
    <SolidColorBrush x:Key="FluentColorText1" Opacity="0.8" Color="{StaticResource FluentGrey9Color}" />
    <SolidColorBrush x:Key="FluentColorText2" Opacity="0.6" Color="{StaticResource FluentGrey9Color}" />
    <SolidColorBrush x:Key="FluentColorText3" Opacity="0.35" Color="{StaticResource FluentGrey9Color}" />

    <!--  Link  -->
    <SolidColorBrush x:Key="FluentColorLink" Color="{StaticResource FluentBlue5Color}" />
    <SolidColorBrush x:Key="FluentColorLinkPointerover" Color="{StaticResource FluentBlue6Color}" />
    <SolidColorBrush x:Key="FluentColorLinkActive" Color="{StaticResource FluentBlue7Color}" />
    <SolidColorBrush x:Key="FluentColorLinkVisited" Color="{StaticResource FluentBlue5Color}" />

    <!--  Background  -->
    <SolidColorBrush x:Key="FluentColorBackground0" Color="{StaticResource FluentBackground0Color}" />
    <SolidColorBrush x:Key="FluentColorBackground1" Color="{StaticResource FluentBackground1Color}" />
    <SolidColorBrush x:Key="FluentColorBackground2" Color="{StaticResource FluentBackground2Color}" />
    <SolidColorBrush x:Key="FluentColorBackground3" Color="{StaticResource FluentBackground3Color}" />
    <SolidColorBrush x:Key="FluentColorBackground4" Color="{StaticResource FluentBackground4Color}" />

    <!--  Fill  -->
    <SolidColorBrush x:Key="FluentColorFill0" Opacity="0.12" Color="{StaticResource FluentWhiteColor}" />
    <SolidColorBrush x:Key="FluentColorFill1" Opacity="0.16" Color="{StaticResource FluentWhiteColor}" />
    <SolidColorBrush x:Key="FluentColorFill2" Opacity="0.20" Color="{StaticResource FluentWhiteColor}" />

    <!--  Border  -->
    <SolidColorBrush x:Key="FluentColorBorder" Opacity="0.08" Color="{StaticResource FluentWhiteColor}" />
    <SolidColorBrush x:Key="FluentColorFocusBorder" Color="{StaticResource FluentBlue5Color}" />

    <!--  Disabled  -->
    <SolidColorBrush x:Key="FluentColorDisabledText" Opacity="0.35" Color="{StaticResource FluentGrey9Color}" />
    <SolidColorBrush x:Key="FluentColorDisabledBorder" Color="{StaticResource FluentGrey1Color}" />
    <SolidColorBrush x:Key="FluentColorDisabledBackground" Color="{StaticResource FluentGrey1Color}" />

    <SolidColorBrush x:Key="FluentColorDisabledFill" Opacity="0.04" Color="{StaticResource FluentGrey8Color}" />

    <!--  Others  -->
    <SolidColorBrush x:Key="FluentColorNavBackground" Color="{StaticResource FluentBackground1Color}" />
    <SolidColorBrush x:Key="FluentColorOverlayBackground" Opacity="0.6" Color="{StaticResource FluentBackground0Color}" />
    <SolidColorBrush x:Key="FluentColorHighlightBackground" Color="{StaticResource FluentYellow4Color}" />
    <SolidColorBrush x:Key="FluentColorHighlight" Color="{StaticResource FluentBlackColor}" />

    <!--  Shadow  -->
    <BoxShadows x:Key="FluentColorShadow">0 0 #0A000000</BoxShadows>
    <BoxShadows x:Key="FluentShadowElevated">inset 0 0 0 1 #1AFFFFFF, 0 4 14 #40000000</BoxShadows>
</ResourceDictionary>