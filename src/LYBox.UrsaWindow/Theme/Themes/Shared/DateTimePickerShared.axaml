<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StaticResource x:Key="DateTimePickerButtonUpGlyph" ResourceKey="FluentIconTriangleUp" />
    <StaticResource x:Key="DateTimePickerButtonDownGlyph" ResourceKey="FluentIconTriangleDown" />
    <StaticResource x:Key="DateTimePickerAcceptGlyph" ResourceKey="FluentIconTick" />
    <StaticResource x:Key="DateTimePickerDismissGlyph" ResourceKey="FluentIconClose" />
    <StaticResource x:Key="DateTimePickerPopupCornerRadius" ResourceKey="FluentBorderRadiusMedium" />
    <x:Double x:Key="DateTimePickerListBoxItemHeight">36</x:Double>
    <StaticResource x:Key="DateTimePickerFlyoutPadding" ResourceKey="FluentThicknessNone" />
    <StaticResource x:Key="DateTimePickerFlyoutBorderMargin" ResourceKey="FluentThicknessTight" />
    <StaticResource x:Key="DateTimePickerButtonSmallHeight" ResourceKey="FluentFontSizeHeader3" />
    <StaticResource x:Key="DateTimePickerButtonDefaultHeight" ResourceKey="FluentFontSizeHeader1" />
    <StaticResource x:Key="DateTimePickerButtonLargeHeight" ResourceKey="FluentHeightControlLarge" />
    <StaticResource x:Key="DateTimePickerButtonBorderThickness" ResourceKey="FluentBorderThicknessControl" />
    <StaticResource x:Key="DateTimePickerButtonCornerRadius" ResourceKey="FluentBorderRadiusSmall" />
</ResourceDictionary>