<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StaticResource x:Key="BannerInformationIconGeometry" ResourceKey="FluentIconInfoCircle" />
    <StaticResource x:Key="BannerSuccessIconGeometry" ResourceKey="FluentIconTickCircle" />
    <StaticResource x:Key="BannerWarningIconGeometry" ResourceKey="FluentIconAlertTriangle" />
    <StaticResource x:Key="BannerErrorIconGeometry" ResourceKey="FluentIconAlertCircle" />
    <StaticResource x:Key="BannerCloseIconGeometry" ResourceKey="FluentIconClose" />

    <CornerRadius x:Key="BannerCornerRadius">3</CornerRadius>
    <Thickness x:Key="BannerBorderPadding">12</Thickness>
    <Thickness x:Key="BannerBorderThickness">1</Thickness>
    <Thickness x:Key="BannerIconMargin">0 0 12 0</Thickness>
    <Thickness x:Key="BannerCloseButtonMargin">12 0 0 0</Thickness>
    <x:Double x:Key="BannerTitleFontSize">18</x:Double>
</ResourceDictionary>