<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StaticResource x:Key="TextBoxDefaultHeight" ResourceKey="FluentHeightControlDefault" />
    <StaticResource x:Key="TextBoxSmallHeight" ResourceKey="FluentHeightControlSmall" />
    <StaticResource x:Key="TextBoxLargeHeight" ResourceKey="FluentHeightControlLarge" />
    <StaticResource x:Key="TextBoxDefaultCornerRadius" ResourceKey="FluentBorderRadiusSmall" />
    <Thickness x:Key="TextBoxInnerLeftContentPadding">0 0 12 0</Thickness>
    <Thickness x:Key="TextBoxInnerRightContentPadding">12 0 0 0</Thickness>
    <Thickness x:Key="TextBoxContentPadding">12 0</Thickness>
    <StaticResource x:Key="TextBoxBorderThickness" ResourceKey="FluentBorderThicknessControl" />
    <Thickness x:Key="TextBoxTextAreaContentPadding">12 5</Thickness>
    <x:Double x:Key="TextBoxTextAreaHeight">90</x:Double>
    <StaticResource x:Key="PasswordBoxRevealButtonData" ResourceKey="FluentIconEyeClosedSolid" />
    <StaticResource x:Key="PasswordBoxHideButtonData" ResourceKey="FluentIconEyeOpened" />
</ResourceDictionary>