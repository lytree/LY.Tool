<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--  Light  -->
    <StaticResource x:Key="ButtonDefaultPrimaryForeground" ResourceKey="FluentColorPrimary" />
    <StaticResource x:Key="ButtonDefaultSecondaryForeground" ResourceKey="FluentColorSecondary" />
    <StaticResource x:Key="ButtonDefaultTertiaryForeground" ResourceKey="FluentColorText1" />
    <StaticResource x:Key="ButtonDefaultSuccessForeground" ResourceKey="FluentColorSuccess" />
    <StaticResource x:Key="ButtonDefaultWarningForeground" ResourceKey="FluentColorWarning" />
    <StaticResource x:Key="ButtonDefaultDangerForeground" ResourceKey="FluentColorDanger" />
    <StaticResource x:Key="ButtonDefaultDisabledForeground" ResourceKey="FluentColorDisabledText" />
    <StaticResource x:Key="ButtonDefaultBackground" ResourceKey="FluentColorFill0" />
    <StaticResource x:Key="ButtonDefaultPointeroverBackground" ResourceKey="FluentColorFill1" />
    <StaticResource x:Key="ButtonDefaultPressedBackground" ResourceKey="FluentColorFill2" />
    <SolidColorBrush x:Key="ButtonDefaultBorderBrush" Color="Transparent" />
    <SolidColorBrush x:Key="ButtonDefaultPointeroverBorderBrush" Color="Transparent" />
    <SolidColorBrush x:Key="ButtonDefaultPressedBorderBrush" Color="Transparent" />
    <SolidColorBrush x:Key="ButtonDefaultDisabledBorderBrush" Color="Transparent" />
    <!--  end Light  -->
    <!--  Solid  -->
    <StaticResource x:Key="ButtonSolidForeground" ResourceKey="FluentColorWhite" />
    <StaticResource x:Key="ButtonSolidPrimaryBackground" ResourceKey="FluentColorPrimary" />
    <StaticResource x:Key="ButtonSolidPrimaryPointeroverBackground" ResourceKey="FluentColorPrimaryPointerover" />
    <StaticResource x:Key="ButtonSolidPrimaryPressedForeground" ResourceKey="FluentColorWhite" />
    <StaticResource x:Key="ButtonSolidPrimaryPressedBackground" ResourceKey="FluentColorPrimaryActive" />
    <StaticResource x:Key="ButtonSolidSecondaryBackground" ResourceKey="FluentColorSecondary" />
    <StaticResource x:Key="ButtonSolidSecondaryPointeroverBackground" ResourceKey="FluentColorSecondaryPointerover" />
    <StaticResource x:Key="ButtonSolidSecondaryPressedBackground" ResourceKey="FluentColorSecondaryActive" />
    <StaticResource x:Key="ButtonSolidTertiaryBackground" ResourceKey="FluentColorTertiary" />
    <StaticResource x:Key="ButtonSolidTertiaryPointeroverBackground" ResourceKey="FluentColorTertiaryPointerover" />
    <StaticResource x:Key="ButtonSolidTertiaryPressedBackground" ResourceKey="FluentColorTertiaryActive" />
    <StaticResource x:Key="ButtonSolidSuccessBackground" ResourceKey="FluentColorSuccess" />
    <StaticResource x:Key="ButtonSolidSuccessPointeroverBackground" ResourceKey="FluentColorSuccessPointerover" />
    <StaticResource x:Key="ButtonSolidSuccessPressedBackground" ResourceKey="FluentColorSuccessActive" />
    <StaticResource x:Key="ButtonSolidWarningBackground" ResourceKey="FluentColorWarning" />
    <StaticResource x:Key="ButtonSolidWarningPointeroverBackground" ResourceKey="FluentColorWarningPointerover" />
    <StaticResource x:Key="ButtonSolidWarningPressedBackground" ResourceKey="FluentColorWarningActive" />
    <StaticResource x:Key="ButtonSolidDangerBackground" ResourceKey="FluentColorDanger" />
    <StaticResource x:Key="ButtonSolidDangerPointeroverBackground" ResourceKey="FluentColorDangerPointerover" />
    <StaticResource x:Key="ButtonSolidDangerPressedBackground" ResourceKey="FluentColorDangerActive" />
    <StaticResource x:Key="ButtonSolidPrimaryBorderBrush" ResourceKey="FluentColorPrimary" />
    <StaticResource x:Key="ButtonSolidPrimaryPointeroverBorderBrush" ResourceKey="FluentColorPrimaryPointerover" />
    <StaticResource x:Key="ButtonSolidPrimaryPressedBorderBrush" ResourceKey="FluentColorPrimaryActive" />
    <StaticResource x:Key="ButtonSolidSecondaryBorderBrush" ResourceKey="FluentColorSecondary" />
    <StaticResource x:Key="ButtonSolidSecondaryPointeroverBorderBrush" ResourceKey="FluentColorSecondaryPointerover" />
    <StaticResource x:Key="ButtonSolidSecondaryPressedBorderBrush" ResourceKey="FluentColorSecondaryActive" />
    <StaticResource x:Key="ButtonSolidTertiaryBorderBrush" ResourceKey="FluentColorTertiary" />
    <StaticResource x:Key="ButtonSolidTertiaryPointeroverBorderBrush" ResourceKey="FluentColorTertiaryPointerover" />
    <StaticResource x:Key="ButtonSolidTertiaryPressedBorderBrush" ResourceKey="FluentColorTertiaryActive" />
    <StaticResource x:Key="ButtonSolidSuccessBorderBrush" ResourceKey="FluentColorSuccess" />
    <StaticResource x:Key="ButtonSolidSuccessPointeroverBorderBrush" ResourceKey="FluentColorSuccessPointerover" />
    <StaticResource x:Key="ButtonSolidSuccessPressedBorderBrush" ResourceKey="FluentColorSuccessActive" />
    <StaticResource x:Key="ButtonSolidWarningBorderBrush" ResourceKey="FluentColorWarning" />
    <StaticResource x:Key="ButtonSolidWarningPointeroverBorderBrush" ResourceKey="FluentColorWarningPointerover" />
    <StaticResource x:Key="ButtonSolidWarningPressedBorderBrush" ResourceKey="FluentColorWarningActive" />
    <StaticResource x:Key="ButtonSolidDangerBorderBrush" ResourceKey="FluentColorDanger" />
    <StaticResource x:Key="ButtonSolidDangerPointeroverBorderBrush" ResourceKey="FluentColorDangerPointerover" />
    <StaticResource x:Key="ButtonSolidDangerPressedBorderBrush" ResourceKey="FluentColorDangerActive" />
    <StaticResource x:Key="ButtonSolidDisabledForeground" ResourceKey="FluentColorDisabledText" />
    <StaticResource x:Key="ButtonSolidDisabledBackground" ResourceKey="FluentColorDisabledBackground" />
    <SolidColorBrush x:Key="ButtonSolidDisabledBorderBrush" Color="Transparent" />
    <!--  end Solid  -->
    <!--  Outline -->
    <SolidColorBrush x:Key="ButtonOutlineBackground" Color="Transparent" />
    <StaticResource x:Key="ButtonOutlineBorderBrush" ResourceKey="FluentColorBorder" />
    <StaticResource x:Key="ButtonOutlinePointeroverBackground" ResourceKey="FluentColorFill0" />
    <StaticResource x:Key="ButtonOutlinePressedBackground" ResourceKey="FluentColorFill1" />
    <StaticResource x:Key="ButtonOutlineSuccessBorderBrush" ResourceKey="FluentColorSuccess" />
    <StaticResource x:Key="ButtonOutlineWarningBorderBrush" ResourceKey="FluentColorWarning" />
    <StaticResource x:Key="ButtonOutlineDangerBorderBrush" ResourceKey="FluentColorDanger" />
    <!--  end Outline  -->
    <!--  Borderless -->
    <SolidColorBrush x:Key="ButtonBorderlessBackground" Color="Transparent" />
    <SolidColorBrush x:Key="ButtonBorderlessBorderBrush" Color="Transparent" />
    <!--  end Borderless  -->

    <!--  Colorful Classes  -->
    <StaticResource x:Key="ButtonDefaultColorfulPrimaryForeground" ResourceKey="FluentColorAIGeneral" />

    <StaticResource x:Key="ButtonSolidColorfulPrimaryBackground" ResourceKey="FluentColorAIGeneral" />
    <StaticResource x:Key="ButtonSolidColorfulPrimaryPointeroverBackground" ResourceKey="FluentColorAIGeneralPointerover" />
    <StaticResource x:Key="ButtonSolidColorfulPrimaryPressedBackground" ResourceKey="FluentColorAIGeneralActive" />
    <StaticResource x:Key="ButtonSolidColorfulTertiaryForeground" ResourceKey="FluentColorAIGeneral" />
    <StaticResource x:Key="ButtonSolidColorfulTertiaryBackground" ResourceKey="FluentAIGeneral0" />
    <StaticResource x:Key="ButtonSolidColorfulTertiaryPointeroverBackground" ResourceKey="FluentAIGeneral1" />
    <StaticResource x:Key="ButtonSolidColorfulTertiaryPressedBackground" ResourceKey="FluentAIGeneral2" />

    <StaticResource x:Key="ButtonOutlineColorfulPrimaryForeground" ResourceKey="FluentColorAIPurple" />
    <StaticResource x:Key="ButtonOutlineColorfulPrimaryBorderBrush" ResourceKey="FluentColorAIPurple" />
    <!-- end Colorful -->

    <StaticResource x:Key="ButtonInputInnerForeground" ResourceKey="FluentColorText2" />
    <StaticResource x:Key="ButtonInputInnerPointeroverForeground" ResourceKey="FluentColorPrimaryPointerover" />
    <StaticResource x:Key="ButtonInputInnerPressedForeground" ResourceKey="FluentColorPrimaryActive" />
</ResourceDictionary>