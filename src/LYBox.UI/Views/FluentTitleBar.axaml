<UserControl
    x:Class="LYBox.UI.Views.FluentTitleBar"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:CompileBindings="False"
    Height="40"
    Background="{DynamicResource TitleBarBackground}"
    d:DesignHeight="40"
    d:DesignWidth="640"
    mc:Ignorable="d">

    <!--
        自绘标题栏：仅在平台不支持扩展客户区（Linux）时显示。
        - 拖动区域（PART_DragRegion）通过 BeginMoveDrag 实现窗口移动；
        - 标题按钮复用全局 CaptionButton ControlTheme，与 Avalonia WindowDrawnDecorations 视觉一致；
        - 关闭按钮的红色悬停态在此局部样式内补齐（WindowDrawnDecorations 的 #PART_CloseButton 选择器不作用于本控件）。
    -->
    <UserControl.Styles>
        <Style Selector="Button#PART_CloseButton">
            <Style Selector="^:pointerover">
                <Setter Property="Foreground" Value="{DynamicResource CaptionButtonCloseForeground}" />
                <Setter Property="Background" Value="{DynamicResource CaptionButtonClosePointeroverBackground}" />
            </Style>
            <Style Selector="^:pressed">
                <Setter Property="Foreground" Value="{DynamicResource CaptionButtonCloseForeground}" />
                <Setter Property="Background" Value="{DynamicResource CaptionButtonClosePressedBackground}" />
            </Style>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="*,Auto">
        <Border
            Name="PART_DragRegion"
            Grid.Column="0"
            Background="Transparent"
            IsHitTestVisible="True">
            <TextBlock
                Margin="12,0,0,0"
                VerticalAlignment="Center"
                FontSize="12"
                Foreground="{DynamicResource WindowDefaultForeground}"
                Text="{Binding $parent[Window].Title, FallbackValue=LYBox}"
                IsHitTestVisible="False" />
        </Border>

        <StackPanel
            Grid.Column="1"
            VerticalAlignment="Stretch"
            Orientation="Horizontal">
            <Button
                Name="PART_MinimizeButton"
                Theme="{StaticResource CaptionButton}"
                Content="{StaticResource FluentIconMinus}" />
            <Button
                Name="PART_MaximizeButton"
                Theme="{StaticResource CaptionButton}"
                Content="{StaticResource FluentIconMaximize2}" />
            <Button
                Name="PART_CloseButton"
                Theme="{StaticResource CaptionButton}"
                Content="{StaticResource FluentIconClose}" />
        </StackPanel>
    </Grid>
</UserControl>
