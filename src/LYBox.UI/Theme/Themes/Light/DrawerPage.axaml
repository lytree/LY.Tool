<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--  DrawerPage background  -->
    <StaticResource x:Key="DrawerPageBackground" ResourceKey="FluentColorBackground0" />
    <StaticResource x:Key="DrawerPageForeground" ResourceKey="FluentColorText0" />
    <!--  Top bar  -->
    <StaticResource x:Key="DrawerPageTopBarBackground" ResourceKey="FluentColorBackground1" />
    <!--  Pane button  -->
    <StaticResource x:Key="DrawerPagePaneButtonForeground" ResourceKey="FluentColorText0" />
</ResourceDictionary>
