<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--  DrawerPage top bar  -->
    <x:Double x:Key="DrawerPageTopBarMinHeight">32</x:Double>

    <!--  DrawerPage pane button  -->
    <StaticResource x:Key="DrawerPageMenuGlyph" ResourceKey="FluentIconMenu" />

    <StaticResource x:Key="DrawerPageTitleFontSize" ResourceKey="FluentFontSizeHeader6" />
    <StaticResource x:Key="DrawerPageTitleFontWeight" ResourceKey="FluentFontWeightBold" />
    <Thickness x:Key="DrawerPageTitleMargin">8 0 0 0</Thickness>
</ResourceDictionary>
