<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StaticResource x:Key="ScrollBarThickness" ResourceKey="FluentSpacingTight" />
    <x:Double x:Key="ScrollBarMinLength">24</x:Double>
    <StaticResource x:Key="ScrollBarThumbThickness" ResourceKey="FluentSpacingTight" />
    <StaticResource x:Key="ScrollBarThumbCornerRadius" ResourceKey="FluentBorderRadiusMedium" />
    <StaticResource x:Key="ScrollBarUpGlyph" ResourceKey="FluentIconSmallTriangleTop" />
    <StaticResource x:Key="ScrollBarDownGlyph" ResourceKey="FluentIconSmallTriangleDown" />
    <StaticResource x:Key="ScrollBarLeftGlyph" ResourceKey="FluentIconSmallTriangleLeft" />
    <StaticResource x:Key="ScrollBarRightGlyph" ResourceKey="FluentIconSmallTriangleRight" />
</ResourceDictionary>