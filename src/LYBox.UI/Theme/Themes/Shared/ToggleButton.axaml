<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StaticResource x:Key="ToggleButtonDefaultFontSize" ResourceKey="FluentFontSizeRegular" />
    <StaticResource x:Key="ToggleButtonDefaultFontWeight" ResourceKey="FluentFontWeightBold" />
    <StaticResource x:Key="ToggleButtonBorderThickness" ResourceKey="FluentBorderThicknessControl" />
    <StaticResource x:Key="ToggleButtonCornerRadius" ResourceKey="FluentBorderRadiusSmall" />
</ResourceDictionary>