<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StaticResource x:Key="CheckBoxFontSize" ResourceKey="FluentFontSizeRegular" />
    <x:Double x:Key="CheckBoxBoxWidth">16</x:Double>
    <x:Double x:Key="CheckBoxBoxHeight">16</x:Double>
    <Thickness x:Key="CheckBoxBoxMargin">0 2 0 0</Thickness>
    <Thickness x:Key="CheckBoxContentMargin">8 0 0 0</Thickness>
    <x:Double x:Key="CheckBoxBoxGlyphWidth">16</x:Double>
    <x:Double x:Key="CheckBoxBoxGlyphHeight">16</x:Double>
    <StaticResource x:Key="CheckBoxBoxCornerRadius" ResourceKey="FluentBorderRadiusSmall" />
    <StaticResource x:Key="CheckBoxBoxBorderThickness" ResourceKey="FluentBorderThicknessControl" />
    <StaticResource x:Key="CheckBoxCheckGlyph" ResourceKey="FluentIconCheckBoxTick" />
    <StaticResource x:Key="CheckBoxIndeterminateGlyph" ResourceKey="FluentIconCheckBoxIndeterminate" />
    <StaticResource x:Key="CheckBoxCardBorderThickness" ResourceKey="FluentBorderThicknessControl" />
    <Thickness x:Key="CheckBoxCardPadding">16 12</Thickness>
    <StaticResource x:Key="CheckBoxCardCornerRadius" ResourceKey="FluentBorderRadiusSmall" />
</ResourceDictionary>