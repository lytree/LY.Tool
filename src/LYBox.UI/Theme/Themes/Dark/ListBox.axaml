<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- ListBox -->
    <StaticResource x:Key="ListBoxItemDisabledForeground" ResourceKey="FluentColorDisabledText" />
    <SolidColorBrush x:Key="ListBoxItemDefaultBackground" Color="Transparent" />
    <StaticResource x:Key="ListBoxItemPointeroverForeground" ResourceKey="FluentColorText0" />
    <StaticResource x:Key="ListBoxItemPointeroverBackground" ResourceKey="FluentColorFill0" />
    <StaticResource x:Key="ListBoxItemPressedForeground" ResourceKey="FluentColorText0" />
    <StaticResource x:Key="ListBoxItemPressedBackground" ResourceKey="FluentColorFill1" />
    <StaticResource x:Key="ListBoxItemSelectedForeground" ResourceKey="FluentColorText0" />
    <StaticResource x:Key="ListBoxItemSelectedBackground" ResourceKey="FluentColorPrimaryLight" />
    <StaticResource x:Key="ListBoxItemSelectedPointeroverBackground" ResourceKey="FluentColorPrimaryLightPointerover" />
    <SolidColorBrush x:Key="ListBoxItemDisabledBackground" Color="Transparent" />
    <StaticResource x:Key="ListBoxItemSelectedDisabledBackground" ResourceKey="FluentColorDisabledFill" />
</ResourceDictionary>