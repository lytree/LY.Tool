<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StaticResource x:Key="TextBlockDefaultForeground" ResourceKey="FluentColorText0" />
    <StaticResource x:Key="TextBlockSecondaryForeground" ResourceKey="FluentColorText1" />
    <StaticResource x:Key="TextBlockTertiaryForeground" ResourceKey="FluentColorText2" />
    <StaticResource x:Key="TextBlockQuaternaryForeground" ResourceKey="FluentColorText3" />
    <StaticResource x:Key="TextBlockSuccessForeground" ResourceKey="FluentColorSuccess" />
    <StaticResource x:Key="TextBlockWarningForeground" ResourceKey="FluentColorWarning" />
    <StaticResource x:Key="TextBlockDangerForeground" ResourceKey="FluentColorDanger" />
    <StaticResource x:Key="TextBlockDisabledForeground" ResourceKey="FluentColorDisabledText" />
    <StaticResource x:Key="TextBlockMarkBackground" ResourceKey="FluentColorPrimaryLight" />
    <StaticResource x:Key="TextBlockCodeForeground" ResourceKey="FluentColorText2" />
    <StaticResource x:Key="TextBlockCodeBackground" ResourceKey="FluentColorFill1" />
    <StaticResource x:Key="TextBlockCodeBorderBrush" ResourceKey="FluentColorBorder" />
    <SolidColorBrush x:Key="TextBlockSelectionBackground" Opacity="0.8" Color="#4CC2FF" />
    <StaticResource x:Key="TextBlockSelectionForeground" ResourceKey="FluentColorWhite" />
</ResourceDictionary>