<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StaticResource x:Key="HyperlinkButtonForeground" ResourceKey="FluentColorLink" />
    <StaticResource x:Key="HyperlinkButtonPointeroverForeground" ResourceKey="FluentColorLinkPointerover" />
    <StaticResource x:Key="HyperlinkButtonPressedForeground" ResourceKey="FluentColorLinkActive" />
    <StaticResource x:Key="HyperlinkButtonDisabledForeground" ResourceKey="FluentColorDisabledText" />
    <StaticResource x:Key="HyperlinkButtonVisitedForeground" ResourceKey="FluentColorLinkVisited" />
</ResourceDictionary>