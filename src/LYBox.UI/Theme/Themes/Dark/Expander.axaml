<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StaticResource x:Key="ExpanderSeparatorBorderBrush" ResourceKey="FluentColorBorder" />
    <StaticResource x:Key="ExpanderHeaderForeground" ResourceKey="FluentColorText0" />
    <StaticResource x:Key="ExpanderHeaderDisabledForeground" ResourceKey="FluentColorDisabledText" />
    <SolidColorBrush x:Key="ExpanderHeaderDefaultBackground" Color="Transparent" />
    <StaticResource x:Key="ExpanderHeaderHoverBackground" ResourceKey="FluentColorFill0" />
    <StaticResource x:Key="ExpanderHeaderPressedBackground" ResourceKey="FluentColorFill1" />
    <StaticResource x:Key="ExpanderContentForeground" ResourceKey="FluentColorText1" />
</ResourceDictionary>