<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StaticResource x:Key="TextBoxTextCaretBrush" ResourceKey="FluentColorWhite" />
    <SolidColorBrush x:Key="TextBoxDefaultBorderBrush" Color="Transparent" />
    <StaticResource x:Key="TextBoxDefaultBackground" ResourceKey="FluentColorFill0" />
    <StaticResource x:Key="TextBoxPointeroverBackground" ResourceKey="FluentColorFill1" />
    <SolidColorBrush x:Key="TextBoxPointeroverBorderBrush" Color="Transparent" />
    <StaticResource x:Key="TextBoxPressedBackground" ResourceKey="FluentColorFill2" />
    <StaticResource x:Key="TextBoxFocusBorderBrush" ResourceKey="FluentColorPrimary" />
    <StaticResource x:Key="TextBoxForeground" ResourceKey="FluentColorText0" />
    <StaticResource x:Key="TextBoxPlaceholderForeground" ResourceKey="FluentColorText2" />
    <StaticResource x:Key="TextBoxInnerForeground" ResourceKey="FluentColorText2" />
    <StaticResource x:Key="TextBoxDisabledBackground" ResourceKey="FluentColorDisabledFill" />
    <StaticResource x:Key="TextBoxDisabledForeground" ResourceKey="FluentColorDisabledText" />
    <SolidColorBrush x:Key="TextBoxDisabledBorderBrush" Color="Transparent" />
    <SolidColorBrush x:Key="TextBoxBorderedDefaultBackground" Color="Transparent" />
    <StaticResource x:Key="TextBoxBorderedDefaultBorderBrush" ResourceKey="FluentColorFill0" />
    <SolidColorBrush x:Key="TextBoxBorderedPointeroverBackground" Color="Transparent" />
    <StaticResource x:Key="TextBoxBorderedPointeroverBorderBrush" ResourceKey="FluentColorPrimaryPointerover" />
    <SolidColorBrush x:Key="TextBoxSelectionBackground" Opacity="0.8" Color="#4CC2FF" />
    <StaticResource x:Key="TextBoxSelectionForeground" ResourceKey="FluentColorWhite" />
</ResourceDictionary>