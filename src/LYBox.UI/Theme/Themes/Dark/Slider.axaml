<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StaticResource x:Key="SliderTrackForeground" ResourceKey="FluentColorPrimary" />
    <StaticResource x:Key="SliderTrackBackground" ResourceKey="FluentColorFill0" />
    <SolidColorBrush x:Key="SliderTickForeground" Color="#3D3D3D" />
    <StaticResource x:Key="SliderThumbBackground" ResourceKey="FluentColorWhite" />
    <StaticResource x:Key="SliderThumbBorderBrush" ResourceKey="FluentColorPrimary" />
    <StaticResource x:Key="SliderThumbPointeroverBorderBrush" ResourceKey="FluentColorPrimaryPointerover" />
    <StaticResource x:Key="SliderThumbPressedBorderBrush" ResourceKey="FluentColorPrimaryActive" />
    <SolidColorBrush x:Key="SliderTrackDisabledForeground" Color="#3D3D3D" />
    <SolidColorBrush x:Key="SliderThumbDisabledBorderBrush" Color="#002B5E" />
    <SolidColorBrush x:Key="SliderTrackDisabledBackground" Color="#1A1A1A" />
</ResourceDictionary>