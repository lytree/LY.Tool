<UserControl
	x:Class="Avalonia.UI.Views.MainView"
	xmlns="https://github.com/avaloniaui"
	xmlns:converters="using:Avalonia.Plugin.Shared.Converters"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:iri="https://irihi.tech/shared"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:plugin="using:Avalonia.Plugin.Shared"
	xmlns:u="https://irihi.tech/ursa"
	xmlns:viewmodels="using:Avalonia.Plugin.Shared.ViewModels"
	xmlns:vm="using:Avalonia.UI.ViewModels"
	d:DesignHeight="450"
	d:DesignWidth="800"
	x:CompileBindings="True"
	x:DataType="vm:MainViewViewModel"
	mc:Ignorable="d">

	<Design.DataContext>
		<vm:MainViewViewModel />
	</Design.DataContext>
	<UserControl.Resources>
		<converters:IconNameToPathConverter x:Key="IconConverter" />
	</UserControl.Resources>
	<Panel>
		<Panel.Styles>
			<Style Selector="Grid.Blur">
				<Setter Property="Effect" Value="blur(10)" />
			</Style>
		</Panel.Styles>
		<Grid Classes.Blur="{Binding $parent[u:UrsaWindow].(u:OverlayDialogHost.IsInModalStatus)}" RowDefinitions="Auto, *">
			<!-- ===== Row 0: WinUI Gallery Full-Width Title Bar (top-bottom structure) ===== -->
			<Border Classes="WinUITitleBar">
				<Grid ColumnDefinitions="Auto, *, Auto">
					<!-- Col 0: Hamburger Toggle Button (WinUI Gallery GlobalNavButton icon) -->
					<Button
						Classes="WinUIHamburger"
						ToolTip.Tip="{DynamicResource TOOLTIP_TOGGLE_SIDEBAR}"
						Command="{Binding ToggleCollapseCommand}"
						VerticalAlignment="Center">
						<PathIcon Width="20" Height="20"
							Data="{DynamicResource FluentLineHorizontal320Regular}"
							Foreground="{DynamicResource SemiColorText0}" />
					</Button>

					<!-- Col 1: Search Box (centered) -->
					<TextBox
						Name="SearchBox"
						Grid.Column="1"
						Classes="WinUISearchBox"
						Width="240"
						HorizontalAlignment="Center"
						VerticalAlignment="Center"
						PlaceholderText="{DynamicResource SEARCH_PLACEHOLDER}"
						Text="{Binding SearchText, Mode=TwoWay}">
						<TextBox.InnerLeftContent>
							<Path Width="14" Height="14"
								Data="{DynamicResource FluentSearch20Regular}"
								Fill="{DynamicResource SemiColorText2}" />
						</TextBox.InnerLeftContent>
					</TextBox>

					<!-- Col 2: Action Buttons -->
					<StackPanel
						Grid.Column="2"
						Orientation="Horizontal"
						Spacing="4"
						VerticalAlignment="Center"
						Margin="0,0,12,0">
						<u:IconButton
						Theme="{StaticResource BorderlessIconButton}"
						Icon="{StaticResource SemiIconGithubLogo}"
						Click="OpenRepository" />
						<u:ThemeToggleButton
							IsThreeState="True"
							Mode="Controller" />
					</StackPanel>
				</Grid>
			</Border>

			<!-- ===== Row 1: Navigation Pane (left) + Content (right) ===== -->
			<Grid Grid.Row="1" ColumnDefinitions="Auto, *">
				<!-- WinUI Gallery Navigation Pane (no logo) -->
				<Border
					VerticalAlignment="Stretch"
					Classes="WinUINavPane"
					IsVisible="{Binding !IsSidebarHidden}">
					<u:NavMenu
						Name="menu"
						CommandBinding="{Binding ActivateCommand}"
						ExpandWidth="280"
						CollapseWidth="48"
						SubMenuBinding="{Binding Children}"
						HeaderBinding="{Binding}"
						IconBinding="{Binding MenuHeader}"
						IsHorizontalCollapsed="{Binding IsCollapsed, Mode=TwoWay}"
						ItemsSource="{Binding Menus.MenuItems}"
						SelectedItem="{Binding SelectedMenuItem, Mode=TwoWay}">
						<u:NavMenu.Styles>
							<Style x:DataType="viewmodels:MenuItemViewModel" Selector="u|NavMenuItem">
								<Setter Property="IsSeparator" Value="{Binding IsSeparator}" />
							</Style>
						</u:NavMenu.Styles>
						<u:NavMenu.IconTemplate>
							<DataTemplate x:DataType="x:String">
								<u:TwoTonePathIcon
									Width="20"
									Height="20"
									ActiveForeground="{DynamicResource FluentAccentBrush}"
									ActiveStrokeBrush="{DynamicResource FluentAccentBrush}"
									Data="{Binding Converter={StaticResource IconConverter}}"
									Foreground="{DynamicResource SemiColorText1}"
									IsActive="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=u:NavMenuItem}, Path=IsHighlighted, Mode=TwoWay}"
									StrokeBrush="{DynamicResource SemiColorText1}" />
							</DataTemplate>
						</u:NavMenu.IconTemplate>
						<u:NavMenu.HeaderTemplate>
							<DataTemplate x:DataType="viewmodels:MenuItemViewModel">
								<StackPanel Orientation="Horizontal" Spacing="8">
									<TextBlock
										HorizontalAlignment="Left"
										FontSize="14"
										Text="{Binding MenuHeader}" />
									<Label
										Theme="{StaticResource TagLabel}"
										Classes="Purple"
										Content="{Binding Status}"
										IsVisible="{Binding Status, Converter={x:Static ObjectConverters.IsNotNull}}" />
								</StackPanel>
							</DataTemplate>
						</u:NavMenu.HeaderTemplate>
						<u:NavMenu.Footer>
							<StackPanel HorizontalAlignment="Stretch" Margin="0,0,0,8">
								<Border Classes="FluentDivider" Margin="8,0,8,8" />
								<StackPanel.Styles>
									<Style Selector="Button.NavFooterItem">
										<Setter Property="Foreground" Value="{DynamicResource SemiColorText1}" />
										<Setter Property="HorizontalContentAlignment" Value="Stretch" />
									</Style>
									<Style Selector="Button.NavFooterItem:pointerover">
										<Setter Property="Background" Value="{DynamicResource FluentSubtleHoverBrush}" />
										<Setter Property="Foreground" Value="{DynamicResource SemiColorText0}" />
									</Style>
									<Style Selector="Button.NavFooterItem:pressed">
										<Setter Property="Background" Value="{DynamicResource FluentSubtlePressedBrush}" />
									</Style>
								</StackPanel.Styles>
								<Button
									Classes="NavFooterItem"
									HorizontalAlignment="Stretch"
									Background="Transparent"
									BorderThickness="0"
									Padding="0"
									CornerRadius="4"
									ToolTip.Tip="{DynamicResource TOOLTIP_SETTINGS}"
									Command="{Binding ActivateCommand}"
									CommandParameter="Settings">
									<Grid ColumnDefinitions="Auto, *">
										<PathIcon
										Width="20" Height="20"
										Margin="14,8,8,8"
										Data="{DynamicResource FluentSettings20Regular}"
										Foreground="{DynamicResource SemiColorText1}" />
										<TextBlock
											Grid.Column="1"
											Margin="0,8,8,8"
											VerticalAlignment="Center"
											FontSize="14"
											Text="{Binding SettingText}"
											IsVisible="{Binding !IsCollapsed}" />
									</Grid>
								</Button>
								<Button
									Classes="NavFooterItem"
									HorizontalAlignment="Stretch"
									Background="Transparent"
									BorderThickness="0"
									Padding="0"
									CornerRadius="4"
									ToolTip.Tip="{DynamicResource TOOLTIP_PLUGIN_MANAGEMENT}"
									Command="{Binding ActivateCommand}"
									CommandParameter="PluginManagement">
									<Grid ColumnDefinitions="Auto, *">
										<PathIcon
										Width="20" Height="20"
										Margin="14,8,8,8"
										Data="{DynamicResource FluentPuzzlePiece20Regular}"
										Foreground="{DynamicResource SemiColorText1}" />
										<TextBlock
											Grid.Column="1"
											Margin="0,8,8,8"
											VerticalAlignment="Center"
											FontSize="14"
											Text="{Binding PluginText}"
											IsVisible="{Binding !IsCollapsed}" />
									</Grid>
								</Button>
							</StackPanel>
						</u:NavMenu.Footer>
					</u:NavMenu>
				</Border>

				<!-- Content Area -->
				<ContentControl Grid.Column="1"
						Margin="36,24"
						Content="{Binding Content}">
					<ContentControl.ContentTemplate>
						<plugin:ViewLocator />
					</ContentControl.ContentTemplate>
				</ContentControl>
			</Grid>
		</Grid>
	</Panel>
</UserControl>
