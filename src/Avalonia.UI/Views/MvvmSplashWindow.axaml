<u:SplashWindow
x:Class="Avalonia.UI.Views.MvvmSplashWindow"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:iri="https://irihi.tech/shared"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:u="https://irihi.tech/ursa"
xmlns:viewModels="clr-namespace:Avalonia.UI.ViewModels"
Title="Starting Ursa Demo..."
Width="720"
Height="420"
Icon="/Assets/Ursa.ico"
x:DataType="viewModels:SplashViewModel"
CountDown="{x:Null}"
mc:Ignorable="d">
	<Border
	Margin="16"
	CornerRadius="20"
	ClipToBounds="True"
	BoxShadow="0 8 24 0 #44000000">
		<Grid ColumnDefinitions="2*,3*">
			<Image
			Grid.Column="0"
			Stretch="UniformToFill"
			Source="/Assets/jk-girl.jpg" />

			<StackPanel
			Grid.Column="1"
			Margin="28"
			VerticalAlignment="Center"
			Spacing="10">
				<TextBlock
				Classes="H2"
				Text="Main Splash Window"
				Theme="{DynamicResource TitleTextBlock}" />
				<TextBlock
				FontSize="16"
				FontWeight="SemiBold"
				Text="二次元 JK 少女启动页" />
				<TextBlock
				Foreground="{DynamicResource SemiColorText2}"
				TextWrapping="Wrap"
				Text="欢迎来到 AvaloniaTemplate，启动页已加载本地图像资源：Assets/jk-girl.png" />
			</StackPanel>
		</Grid>
	</Border>
</u:SplashWindow>
