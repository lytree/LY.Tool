<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Avalonia.UI.ViewModels"
             x:Class="Avalonia.UI.Pages.PluginManagementPage"
             x:DataType="viewModels:PluginManagementViewModel"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600">
    <Grid Margin="24" RowDefinitions="Auto,Auto,*">
        
        <StackPanel Grid.Row="0" Spacing="8" Margin="0 0 0 20">
            <TextBlock Text="Plugin Management" Theme="{StaticResource TitleTextBlock}" Classes="H3" />
            <TextBlock Text="Install, uninstall, enable or disable plugins" Classes="Secondary" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0 0 0 16">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Install Plugin" Command="{Binding InstallPluginCommand}" IsEnabled="{Binding !IsInstalling}"
                        Classes="FluentAccent"/>
                <Button Content="Refresh" Command="{Binding RefreshPluginsCommand}"/>
            </StackPanel>
            <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" VerticalAlignment="Center" Classes="Secondary" />
        </Grid>

        <ProgressBar Grid.Row="1" IsVisible="{Binding IsInstalling}" Value="{Binding InstallProgress}" 
                     Height="4" Margin="0 40 0 0" IsIndeterminate="False"/>

        <ScrollViewer Grid.Row="2">
            <StackPanel Spacing="8">
                <ItemsControl ItemsSource="{Binding Plugins}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:PluginItemViewModel">
                            <Border Theme="{DynamicResource CardBorder}" Margin="0 0 0 4">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto">
                                    
                                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding Name}" Theme="{StaticResource TitleTextBlock}" Classes="H6" />
                                        <Border CornerRadius="4" Padding="6 2" Background="{Binding StateColor}">
                                            <TextBlock Text="{Binding StateText}" FontSize="11" Foreground="White"/>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                        <Button Content="Enable" 
                                                Command="{Binding $parent[UserControl].DataContext.EnablePluginCommand}" 
                                                CommandParameter="{Binding}"
                                                IsVisible="{Binding CanEnable}"
                                                Classes="small"/>
                                        <Button Content="Disable" 
                                                Command="{Binding $parent[UserControl].DataContext.DisablePluginCommand}" 
                                                CommandParameter="{Binding}"
                                                IsVisible="{Binding CanDisable}"
                                                Classes="small"/>
                                        <Button Content="Uninstall" 
                                                Command="{Binding $parent[UserControl].DataContext.UninstallPluginCommand}" 
                                                CommandParameter="{Binding}"
                                                IsVisible="{Binding CanUninstall}"
                                                Classes="small"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="16" Margin="0 4 0 0">
                                        <TextBlock FontSize="12" Classes="Tertiary">
                                            <Run Text="Version: "/><Run Text="{Binding Version}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="12" Classes="Tertiary">
                                            <Run Text="Author: "/><Run Text="{Binding Author}"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding Description}" 
                                               Classes="Secondary" Margin="0 4 0 0"
                                               TextWrapping="Wrap" MaxHeight="40"/>

                                    <TextBlock Grid.Row="3" Grid.ColumnSpan="2" Text="{Binding ErrorMessage}" 
                                               FontSize="12" Classes="Danger" Margin="0 4 0 0"
                                               IsVisible="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                                               TextWrapping="Wrap"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border IsVisible="{Binding Plugins.Count, Converter={x:Static viewModels:PluginStateConverters.IsEmpty}}"
                        Theme="{DynamicResource CardBorder}" Padding="32"
                        HorizontalAlignment="Center" Margin="0 40 0 0">
                    <StackPanel HorizontalAlignment="Center" Spacing="8">
                        <TextBlock Text="No plugins installed" FontSize="16" 
                                   Classes="Tertiary" HorizontalAlignment="Center"/>
                        <TextBlock Text="Click 'Install Plugin' to add a new plugin" FontSize="13" 
                                   Classes="Tertiary" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
