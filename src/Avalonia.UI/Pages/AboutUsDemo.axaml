<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:collections="clr-namespace:Avalonia.Collections;assembly=Avalonia.Base"
             xmlns:iri="https://irihi.tech/shared"
             xmlns:viewModels="clr-namespace:Avalonia.UI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800"
             d:DesignHeight="450"
             x:DataType="viewModels:AboutUsDemoViewModel"
             x:Class="Avalonia.UI.Pages.AboutUsDemo">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <collections:AvaloniaList x:Key="CanvasPalette" x:TypeArguments="Color">
                        <Color>#FF0078D4</Color>
                        <Color>#FF106EBE</Color>
                        <Color>#FF005A9E</Color>
                        <Color>#FF004578</Color>
                        <Color>#FF2B88D8</Color>
                        <Color>#FF4CA0E0</Color>
                        <Color>#FF6CB8E8</Color>
                    </collections:AvaloniaList>
                    <LinearGradientBrush x:Key="TileTitleForeground">
                        <GradientStop Offset="0.0" Color="#FF0078D4" />
                        <GradientStop Offset="0.5" Color="#FF106EBE" />
                        <GradientStop Offset="1.0" Color="#FF005A9E" />
                    </LinearGradientBrush>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <collections:AvaloniaList x:Key="CanvasPalette" x:TypeArguments="Color">
                        <Color>#FF60CDFF</Color>
                        <Color>#FF4CC2FF</Color>
                        <Color>#FF38B8FF</Color>
                        <Color>#FF2BA8E6</Color>
                        <Color>#FF1E99CC</Color>
                        <Color>#FF118AB2</Color>
                        <Color>#FF0A7A99</Color>
                    </collections:AvaloniaList>
                    <LinearGradientBrush x:Key="TileTitleForeground">
                        <GradientStop Offset="0.0" Color="#FF60CDFF" />
                        <GradientStop Offset="0.5" Color="#FF4CC2FF" />
                        <GradientStop Offset="1.0" Color="#FF38B8FF" />
                    </LinearGradientBrush>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <UserControl.Styles>
        <Style Selector="TextBlock.TileTitle">
            <Setter Property="FontWeight" Value="700" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Foreground" Value="{DynamicResource TileTitleForeground}" />
        </Style>
    </UserControl.Styles>
    <Grid RowDefinitions="*, Auto">
        <ScrollViewer>
            <StackPanel Margin="36,24">
                <!-- WinUI Gallery Hero Section -->
                <Grid
                    Margin="0,32,0,48"
                    HorizontalAlignment="Center"
                    ColumnDefinitions="*, *"
                    RowDefinitions="*, *">
                    <iri:IrihiLogo
                        Grid.Row="0"
                        Grid.RowSpan="2"
                        Grid.Column="0"
                        Fill="{DynamicResource FluentAccentBrush}"
                        Width="96"
                        Margin="0,0,24,0"
                        VerticalAlignment="Center" />
                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="1"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        FontSize="48"
                        FontWeight="700"
                        Text="{DynamicResource COMPANY_NAME_CN}" />
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="1"
                        Margin="12,0,0,0"
                        HorizontalAlignment="Left"
                        FontSize="16"
                        Text="{DynamicResource COMPANY_NAME_EN}"
                        Classes="WinUIBody" />
                </Grid>
                <TextBlock
                    HorizontalAlignment="Center"
                    Classes="WinUISubtitle"
                    Text="{DynamicResource SLOGAN_CN}" />
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="20"
                    Text="{DynamicResource SLOGAN_EN}"
                    Classes="WinUIBody" />

                <!-- WinUI Gallery Card Grid -->
                <UniformGrid
                    MaxWidth="810"
                    Margin="0,0,0,24"
                    HorizontalAlignment="Center"
                    Columns="2">
                    <Button
                        Margin="8"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="semi"
                        Classes="WinUICard">
                        <StackPanel HorizontalAlignment="Left">
                            <TextBlock Classes="TileTitle" Text="Semi" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Label Theme="{DynamicResource TagLabel}" Classes="Blue Ghost" Content="{DynamicResource OPEN_SOURCE}" />
                            </StackPanel>
                            <TextBlock Text="{DynamicResource SEMI_DESC_CN}"
                                       Classes="WinUIBody" />
                            <TextBlock Text="{DynamicResource SEMI_DESC_EN}"
                                       Classes="WinUICaption" />
                        </StackPanel>
                    </Button>
                    <Button
                        Margin="8"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="ursa"
                        Classes="WinUICard">
                        <StackPanel HorizontalAlignment="Left">
                            <TextBlock Classes="TileTitle" Text="Ursa" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Label Theme="{DynamicResource TagLabel}" Classes="Blue Ghost" Content="{DynamicResource OPEN_SOURCE}" />
                            </StackPanel>
                            <TextBlock Text="{DynamicResource URSA_DESC_CN}"
                                       Classes="WinUIBody" />
                            <TextBlock Text="{DynamicResource URSA_DESC_EN}"
                                       Classes="WinUICaption" />
                        </StackPanel>
                    </Button>
                    <Button
                        Margin="8"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="mantra"
                        Classes="WinUICard">
                        <StackPanel HorizontalAlignment="Left">
                            <TextBlock Classes="TileTitle" Text="Mantra" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Label Theme="{DynamicResource TagLabel}" Classes="Purple Ghost" Content="{DynamicResource COMMERCIAL}" />
                            </StackPanel>
                            <TextBlock Text="{DynamicResource MANTRA_DESC_CN}"
                                       Classes="WinUIBody" />
                            <TextBlock Text="{DynamicResource MANTRA_DESC_EN}"
                                       Classes="WinUICaption" />
                        </StackPanel>
                    </Button>
                    <Button
                        Margin="8"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="huska"
                        Classes="WinUICard">
                        <StackPanel HorizontalAlignment="Left">
                            <TextBlock Classes="TileTitle" Text="Huska" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Label Theme="{DynamicResource TagLabel}" Classes="Purple Ghost" Content="{DynamicResource COMMERCIAL}" />
                            </StackPanel>
                            <TextBlock Text="{DynamicResource HUSKA_DESC_CN}"
                                       Classes="WinUIBody" />
                            <TextBlock Text="{DynamicResource HUSKA_DESC_EN}"
                                       Classes="WinUICaption" />
                        </StackPanel>
                    </Button>
                </UniformGrid>
            </StackPanel>
        </ScrollViewer>
        <StackPanel
            Grid.Row="1"
            Margin="0,16"
            Spacing="32"
            HorizontalAlignment="Center"
            Orientation="Horizontal">
            <StackPanel Orientation="Horizontal">
                <HyperlinkButton
                    Classes="WithIcon"
                    VerticalAlignment="Center"
                    Content="{DynamicResource HOMEPAGE}"
                    NavigateUri="https://irihi.tech">
                    <HyperlinkButton.Styles>
                        <Style Selector=".WithIcon /template/ PathIcon">
                            <Setter Property="Data" Value="{StaticResource SemiIconHome}" />
                        </Style>
                    </HyperlinkButton.Styles>
                </HyperlinkButton>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <HyperlinkButton
                    Classes="WithIcon"
                    Content="GitHub"
                    NavigateUri="https://github.com/irihitech">
                    <HyperlinkButton.Styles>
                        <Style Selector=".WithIcon /template/ PathIcon">
                            <Setter Property="Data" Value="{StaticResource SemiIconGithubLogo}" />
                        </Style>
                    </HyperlinkButton.Styles>
                </HyperlinkButton>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
