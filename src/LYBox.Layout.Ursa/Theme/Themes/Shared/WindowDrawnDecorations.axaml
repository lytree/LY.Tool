<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StaticResource x:Key="WindowCloseIconGlyph" ResourceKey="FluentIconClose" />
    <StaticResource x:Key="WindowMinimizeGlyph" ResourceKey="FluentIconMinus" />
    <StaticResource x:Key="WindowExpandGlyph" ResourceKey="FluentIconExpand" />
    <StaticResource x:Key="WindowCollapseGlyph" ResourceKey="FluentIconShrink" />
    <StaticResource x:Key="WindowMaximizeGlyph" ResourceKey="FluentIconMaximize2" />
    <StaticResource x:Key="WindowRestoreGlyph" ResourceKey="FluentIconRestore" />

    <StaticResource x:Key="CaptionButtonCornerRadius" ResourceKey="FluentBorderRadiusSmall" />
    <StaticResource x:Key="CaptionButtonWidth" ResourceKey="FluentSpacingExtraLoose" />
    <StaticResource x:Key="CaptionButtonHeight" ResourceKey="FluentSpacingExtraLoose" />
    <StaticResource x:Key="CaptionButtonPadding" ResourceKey="FluentThicknessTight" />
</ResourceDictionary>