<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StaticResource x:Key="ButtonDefaultFontSize" ResourceKey="FluentFontSizeRegular" />
    <StaticResource x:Key="ButtonDefaultFontWeight" ResourceKey="FluentFontWeightBold" />
    <Thickness x:Key="ButtonDefaultPadding">12 0</Thickness>
    <Thickness x:Key="ButtonLargePadding">16 0</Thickness>
    <Thickness x:Key="ButtonSmallPadding">6 0</Thickness>
    <StaticResource x:Key="ButtonDefaultHeight" ResourceKey="FluentHeightControlDefault" />
    <StaticResource x:Key="ButtonSmallHeight" ResourceKey="FluentHeightControlSmall" />
    <StaticResource x:Key="ButtonLargeHeight" ResourceKey="FluentHeightControlLarge" />
    <StaticResource x:Key="ButtonBorderThickness" ResourceKey="FluentBorderThicknessControl" />
    <StaticResource x:Key="ButtonCornerRadius" ResourceKey="FluentBorderRadiusSmall" />
    <StaticResource x:Key="IconButtonClearData" ResourceKey="FluentIconClear" />
</ResourceDictionary>