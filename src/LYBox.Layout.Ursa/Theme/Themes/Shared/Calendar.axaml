<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StaticResource x:Key="CalendarBorderThickness" ResourceKey="FluentBorderThicknessControl" />
    <StaticResource x:Key="CalendarCornerRadius" ResourceKey="FluentBorderRadiusMedium" />
    <GridLength x:Key="CalendarItemWeekDayNameHeight">40</GridLength>
    <StaticResource x:Key="CalendarItemWeekDayNameFontWeight" ResourceKey="FluentFontWeightBold" />
    <StaticResource x:Key="CalendarItemPreviousIconGlyph" ResourceKey="FluentIconChevronLeft" />
    <StaticResource x:Key="CalendarItemNextIconGlyph" ResourceKey="FluentIconChevronRight" />
    <StaticResource x:Key="CalendarItemCalendarButtonSelectedFontWeight" ResourceKey="FluentFontWeightBold" />
    <StaticResource x:Key="CalendarItemCalendarButtonCornerRadius" ResourceKey="FluentBorderRadiusSmall" />
    <StaticResource x:Key="CalendarItemCalendarDayButtonCornerRadius" ResourceKey="FluentBorderRadiusSmall" />
    <x:Double x:Key="CalendarMinWidth">240</x:Double>
    <x:Double x:Key="CalendarMinHeight">250</x:Double>
    <StaticResource x:Key="CalendarItemWeekDayNameFontSize" ResourceKey="FluentFontSizeSmall" />
</ResourceDictionary>