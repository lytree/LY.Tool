<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StaticResource x:Key="FlyoutFontWeight" ResourceKey="FluentFontWeightRegular" />
    <StaticResource x:Key="FlyoutBorderThickness" ResourceKey="FluentBorderThicknessControl" />
    <x:Double x:Key="FlyoutMinHeight">100</x:Double>
    <x:Double x:Key="FlyoutMinWidth">100</x:Double>
    <x:Double x:Key="FlyoutMaxHeight">600</x:Double>
    <x:Double x:Key="FlyoutMaxWidth">600</x:Double>
    <StaticResource x:Key="FlyoutCornerRadius" ResourceKey="FluentBorderRadiusMedium" />
    <StaticResource x:Key="FlyoutPadding" ResourceKey="FluentThicknessTight" />
    <StaticResource x:Key="HorizontalMenuFlyoutThemeMinWidth" ResourceKey="FluentSpacingExtraLoose" />
</ResourceDictionary>