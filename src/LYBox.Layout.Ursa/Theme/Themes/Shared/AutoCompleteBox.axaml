<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StaticResource x:Key="AutoCompleteBoxPopupBorderThickness" ResourceKey="FluentBorderThicknessControl" />
    <StaticResource x:Key="AutoCompleteBoxPopupMargin" ResourceKey="FluentThicknessExtraTight" />
    <Thickness x:Key="AutoCompleteBoxPopupPadding">0 4</Thickness>
    <StaticResource x:Key="AutoCompleteBoxPopupCornerRadius" ResourceKey="FluentBorderRadiusMedium" />
    <StaticResource x:Key="AutoCompleteBoxDefaultHeight" ResourceKey="FluentHeightControlDefault" />
    <StaticResource x:Key="AutoCompleteBoxSmallHeight" ResourceKey="FluentHeightControlSmall" />
    <StaticResource x:Key="AutoCompleteBoxLargeHeight" ResourceKey="FluentHeightControlLarge" />
    <x:Double x:Key="AutoCompleteMaxDropdownHeight">600</x:Double>
</ResourceDictionary>