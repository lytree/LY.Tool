<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StaticResource x:Key="ButtonSpinnerIncreaseButtonGlyph" ResourceKey="FluentIconChevronUp" />
    <StaticResource x:Key="ButtonSpinnerDecreaseButtonGlyph" ResourceKey="FluentIconChevronDown" />
    <StaticResource x:Key="ButtonSpinnerButtonGroupCornerRadius" ResourceKey="FluentBorderRadiusSmall" />
    <StaticResource x:Key="ButtonSpinnerButtonGroupBorderThickness" ResourceKey="FluentBorderThicknessControl" />

    <StaticResource x:Key="SplitButtonSpinnerIncreaseButtonGlyph" ResourceKey="FluentIconPlus" />
    <StaticResource x:Key="SplitButtonSpinnerDecreaseButtonGlyph" ResourceKey="FluentIconMinus" />
    <CornerRadius x:Key="SplitButtonSpinnerLeftButtonCornerRadius">3 0 0 3</CornerRadius>
    <CornerRadius x:Key="SplitButtonSpinnerRightButtonCornerRadius">0 3 3 0</CornerRadius>
    <Thickness x:Key="SplitButtonSpinnerButtonPadding">8 0</Thickness>
</ResourceDictionary>