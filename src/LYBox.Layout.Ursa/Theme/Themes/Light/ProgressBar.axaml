<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StaticResource x:Key="ProgressBarIndicatorBrush" ResourceKey="FluentColorPrimary" />
    <StaticResource x:Key="ProgressBarBackground" ResourceKey="FluentColorFill0" />
    <StaticResource x:Key="ProgressBarTextForeground" ResourceKey="FluentColorText0" />
    <SolidColorBrush x:Key="ProgressBarRootBorderBrush" Color="Transparent" />
    <StaticResource x:Key="ProgressBarPrimaryForeground" ResourceKey="FluentColorPrimary" />
    <StaticResource x:Key="ProgressBarSecondaryForeground" ResourceKey="FluentColorSecondary" />
    <StaticResource x:Key="ProgressBarTertiaryForeground" ResourceKey="FluentColorTertiary" />
    <StaticResource x:Key="ProgressBarSuccessForeground" ResourceKey="FluentColorSuccess" />
    <StaticResource x:Key="ProgressBarWarningForeground" ResourceKey="FluentColorWarning" />
    <StaticResource x:Key="ProgressBarDangerForeground" ResourceKey="FluentColorDanger" />
</ResourceDictionary>