<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StaticResource x:Key="TreeViewItemDefaultForeground" ResourceKey="FluentColorText0" />
    <StaticResource x:Key="TreeViewItemIconDefaultForeground" ResourceKey="FluentColorText2" />
    <StaticResource x:Key="TreeViewItemIconHoverForeground" ResourceKey="FluentColorText0" />
    <StaticResource x:Key="TreeViewItemDisabledForeground" ResourceKey="FluentColorDisabledText" />
    <SolidColorBrush x:Key="TreeViewItemDefaultBackground" Color="Transparent" />
    <StaticResource x:Key="TreeViewItemPointeroverForeground" ResourceKey="FluentColorText0" />
    <StaticResource x:Key="TreeViewItemPointeroverBackground" ResourceKey="FluentColorFill0" />
    <StaticResource x:Key="TreeViewItemPressedBackground" ResourceKey="FluentColorFill1" />
    <StaticResource x:Key="TreeViewItemSelectedForeground" ResourceKey="FluentColorText0" />
    <StaticResource x:Key="TreeViewItemSelectedBackground" ResourceKey="FluentColorPrimaryLight" />
    <SolidColorBrush x:Key="TreeViewItemDisabledBackground" Color="Transparent" />
    <StaticResource x:Key="TreeViewItemSelectedDisabledBackground" ResourceKey="FluentColorDisabledFill" />
</ResourceDictionary>