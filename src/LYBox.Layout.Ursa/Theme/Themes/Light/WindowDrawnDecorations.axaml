<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StaticResource x:Key="WindowBorderShadow" ResourceKey="FluentShadowElevated" />
    <StaticResource x:Key="WindowBackground" ResourceKey="FluentColorBackground0" />
    <StaticResource x:Key="WindowBorderBrush" ResourceKey="FluentCardStrokeBrush" />
    <StaticResource x:Key="TitleBarBackground" ResourceKey="FluentColorBackground0" />

    <!-- 失焦状态：标题栏与边框使用更亮的灰色，与 WinUI 3 inactive 行为一致 -->
    <SolidColorBrush x:Key="TitleBarInactiveBackground" Color="#F9F9F9" />
    <SolidColorBrush x:Key="WindowInactiveBackground" Color="#F9F9F9" />
    <SolidColorBrush x:Key="WindowInactiveBorderBrush" Color="#EAEAEA" />

    <StaticResource x:Key="CaptionButtonPointeroverBackground" ResourceKey="FluentColorFill1" />
    <StaticResource x:Key="CaptionButtonPressedBackground" ResourceKey="FluentColorFill2" />
    <StaticResource x:Key="CaptionButtonCloseForeground" ResourceKey="FluentColorWhite" />
    <StaticResource x:Key="CaptionButtonClosePointeroverBackground" ResourceKey="FluentColorDangerPointerover" />
    <StaticResource x:Key="CaptionButtonClosePressedBackground" ResourceKey="FluentColorDangerActive" />
    <StaticResource x:Key="CaptionButtonForeground" ResourceKey="FluentColorText1" />
    <StaticResource x:Key="CaptionButtonDisabledForeground" ResourceKey="FluentColorDisabledText" />
    <!-- 失焦时 CaptionButton 前景更淡（WinUI 3 inactive caption） -->
    <SolidColorBrush x:Key="CaptionButtonInactiveForeground" Opacity="0.5" Color="#3D3D3D" />
</ResourceDictionary>