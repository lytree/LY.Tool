<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <LinearGradientBrush x:Key="SkeletonStartAnimationBackground" StartPoint="0%,100%" EndPoint="100%,100%">
        <GradientStop Offset="0" Color="#1A1A1A" />
        <GradientStop Offset="0" Color="#2B2B2B" />
        <GradientStop Offset="1" Color="#1A1A1A" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="SkeletonEndAnimationBackground" StartPoint="0%,100%" EndPoint="100%,100%">
        <GradientStop Offset="0" Color="#1A1A1A" />
        <GradientStop Offset="1" Color="#2B2B2B" />
        <GradientStop Offset="1" Color="#1A1A1A" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="SkeletonDefaultBackground" Color="#1A1A1A" />
</ResourceDictionary>