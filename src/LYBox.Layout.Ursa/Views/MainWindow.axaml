<u:UrsaWindow
    x:Class="LYBox.Layout.Ursa.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:u="https://irihi.tech/ursa"
    xmlns:viewModels="clr-namespace:LYBox.Layout.Ursa.ViewModels"
    xmlns:views="clr-namespace:LYBox.Layout.Ursa.Views"
    xmlns:iri="https://irihi.tech/shared"
    Title="{DynamicResource WINDOW_TITLE}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:CompileBindings="True"
    ExtendClientAreaToDecorationsHint="True"
    x:DataType="viewModels:MainWindowViewModel"
    WindowStartupLocation="CenterScreen"
    Icon="/Assets/lybox.ico"
    IsFullScreenButtonVisible="{OnPlatform {x:True}, macOS={x:False}}"
    IsManagedResizerVisible="{OnPlatform {x:False}, Linux={x:True}}"
    mc:Ignorable="d">
    <u:UrsaWindow.RightContent>
        <views:TitleBarRightContent />
    </u:UrsaWindow.RightContent>
    <views:MainView />
</u:UrsaWindow>
