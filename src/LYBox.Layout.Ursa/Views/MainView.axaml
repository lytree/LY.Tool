<UserControl
    x:Class="LYBox.Layout.Ursa.Views.MainView"
    xmlns="https://github.com/avaloniaui"
    xmlns:converters="using:LYBox.Plugin.Shared.Converters"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:iri="https://irihi.tech/shared"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:plugin="using:LYBox.Plugin.Shared"
    xmlns:u="https://irihi.tech/ursa"
    xmlns:viewmodels="using:LYBox.Plugin.Shared.ViewModels"
    xmlns:vm="using:LYBox.Layout.Ursa.ViewModels"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:CompileBindings="True"
    x:DataType="vm:MainViewViewModel"
    mc:Ignorable="d">

    <Design.DataContext>
        <vm:MainViewViewModel />
    </Design.DataContext>
    <UserControl.Resources>
        <converters:IconNameToPathConverter x:Key="IconConverter" />
    </UserControl.Resources>
    <Panel>
        <Panel.Styles>
            <Style Selector="Grid.Blur">
                <Setter Property="Effect" Value="blur(10)" />
            </Style>
        </Panel.Styles>
        <!-- WinUI 风格布局：左侧 Ursa NavMenu + 右侧内容区。
             顶部 Margin=48 让出 UrsaWindow TitleBar 高度，避免 NavMenu 与汉堡按钮重合。 -->
        <Grid Classes.Blur="{Binding $parent[u:UrsaWindow].(u:OverlayDialogHost.IsInModalStatus)}"
              Margin="0,48,0,0"
              ColumnDefinitions="Auto,*">
            <!-- 左侧导航栏：汉堡按钮已移至 UrsaWindow.LeftContent（TitleBar 左侧），
                 避免 TitleBar 覆盖 MainView 顶部 48px 拦截点击。 -->
            <Border Classes="FluentNavPane" Grid.Column="0">
                <Grid RowDefinitions="*,Auto">
                    <!-- NavMenu 菜单列表（无 Header/Footer，纯菜单项） -->
                    <u:NavMenu
                        Name="NavMenu"
                        Grid.Row="0"
                        Background="Transparent"
                        IsHorizontalCollapsed="{Binding IsCollapsed}"
                        ItemsSource="{Binding Menus.MenuItems}"
                        SelectedItem="{Binding SelectedMenuItem, Mode=TwoWay}"
                        ExpandWidth="260"
                        CollapseWidth="48"
                        HeaderBinding="{Binding MenuHeader}"
                        SubMenuBinding="{Binding Children}">
                        <u:NavMenu.IconTemplate>
                            <DataTemplate x:DataType="viewmodels:MenuItemViewModel">
                                <PathIcon
                                    Width="20" Height="20"
                                    Data="{Binding MenuIconName, Converter={StaticResource IconConverter}}"
                                    Foreground="{DynamicResource FluentColorText1}" />
                            </DataTemplate>
                        </u:NavMenu.IconTemplate>
                    </u:NavMenu>
                    <!-- 底部：设置 + 插件管理 -->
                    <StackPanel Grid.Row="1" HorizontalAlignment="Stretch" Margin="0,0,0,8">
                        <Border Classes="FluentDivider" Margin="8,0,8,8" />
                        <Button
                            Classes="FluentNavToggle"
                            HorizontalAlignment="Stretch"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            CornerRadius="4"
                            ToolTip.Tip="{DynamicResource TOOLTIP_SETTINGS}"
                            Command="{Binding ActivateCommand}"
                            CommandParameter="Settings">
                            <Grid ColumnDefinitions="Auto,*">
                                <PathIcon
                                    Width="20" Height="20"
                                    Margin="14,8,8,8"
                                    Data="{DynamicResource FluentSettings20Regular}"
                                    Foreground="{DynamicResource FluentColorText1}" />
                                <TextBlock
                                    Grid.Column="1"
                                    Margin="0,8,8,8"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    Text="{Binding SettingText}"
                                    IsVisible="{Binding !IsCollapsed}" />
                            </Grid>
                        </Button>
                        <Button
                            Classes="FluentNavToggle"
                            HorizontalAlignment="Stretch"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            CornerRadius="4"
                            ToolTip.Tip="{DynamicResource TOOLTIP_PLUGIN_MANAGEMENT}"
                            Command="{Binding ActivateCommand}"
                            CommandParameter="PluginManagement">
                            <Grid ColumnDefinitions="Auto,*">
                                <PathIcon
                                    Width="20" Height="20"
                                    Margin="14,8,8,8"
                                    Data="{DynamicResource FluentPuzzlePiece20Regular}"
                                    Foreground="{DynamicResource FluentColorText1}" />
                                <TextBlock
                                    Grid.Column="1"
                                    Margin="0,8,8,8"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    Text="{Binding PluginText}"
                                    IsVisible="{Binding !IsCollapsed}" />
                            </Grid>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 右侧内容区 -->
            <ContentControl
                Grid.Column="1"
                Margin="36,24"
                Content="{Binding Content}">
                <ContentControl.ContentTemplate>
                    <plugin:ViewLocator />
                </ContentControl.ContentTemplate>
            </ContentControl>
        </Grid>
    </Panel>
</UserControl>
