<Application
x:Class="Avalonia.Launcher.Desktop.App"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:semi="https://irihi.tech/semi"
    xmlns:u="https://irihi.tech/ursa"
    xmlns:iri="https://irihi.tech/shared"
    RequestedThemeVariant="Light"
xmlns:viewmodels="using:Avalonia.UI.ViewModels"
x:DataType="viewmodels:ApplicationViewModel">
    <Application.Styles>
        <semi:SemiTheme Locale="zh-CN" />
        <semi:UrsaSemiTheme Locale="zh-CN" />
        <semi:SemiPopupAnimations />
        <!--This style is created to demonstrate Dialog StyleClass feature. This style is applied to Dialog Window-->
        <Style Selector="u|StandardDialogWindow.Custom">
            <Style Selector="^ /template/ Button#PART_OKButton">
                <Setter Property="Content" Value="CUSTOM" />
                <Setter Property="iri:ClassHelper.Classes" Value="Warning" />
            </Style>
        </Style>
    </Application.Styles>
	<Application.Resources>
		<!-- 定义矢量图标资源 -->
		<StreamGeometry x:Key="Icon_About">M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z</StreamGeometry>
	</Application.Resources>
	<NativeMenu.Menu>
		<NativeMenu>
			<NativeMenuItem
			Header="About Us"
			Command="{Binding JumpToCommand}"
			CommandParameter="AboutUs"/>
		</NativeMenu>
	</NativeMenu.Menu>
</Application>
