<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fluent="using:Avalonia.Themes.Fluent"
             x:Class="LYBox.FluentWindow.App">
    <Application.Styles>
        <fluent:FluentTheme />
        <StyleInclude Source="avares://LYBox.FluentWindow/Themes/FluentWindowStyle.axaml" />
    </Application.Styles>
</Application>
