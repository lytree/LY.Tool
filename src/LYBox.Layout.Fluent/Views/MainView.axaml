<UserControl
  x:Class="LYBox.Layout.Fluent.Views.MainView"
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:fui="clr-namespace:AvaloniaFluentUI.Controls;assembly=LYBox.Layout.Fluent"
  xmlns:vm="using:LYBox.Layout.Fluent.ViewModels"
  x:DataType="vm:MainWindowViewModel"
  Background="{DynamicResource SystemBrush}">

  <Design.DataContext>
    <vm:MainWindowViewModel/>
  </Design.DataContext>

  <UserControl.Styles>
    <Style Selector="UserControl">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
  </UserControl.Styles>

