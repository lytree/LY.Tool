          <fui:SettingsExpanderItem Margin="-24,0,0,0">
            <StackPanel HorizontalAlignment="Left" Orientation="Vertical">
              <RadioButton
                Name="CustomColorRadioButton"
                Content="{Binding CustomColor}"
                IsChecked="{Binding IsCustomColor}"/>
              <RadioButton Content="{Binding DefaultColor}" IsChecked="{Binding IsDefaultAccentColor}"/>
            </StackPanel>
          </fui:SettingsExpanderItem>
          <fui:SettingsExpanderItem Margin="-24,0,0,0" Content="{Binding CustomColor}">
            <fui:SettingsExpanderItem.Footer>
              <Grid ColumnDefinitions="Auto, *" IsEnabled="{Binding #CustomColorRadioButton.IsChecked}">
                <TextBlock
                  Grid.Column="0"
                  Margin="0,0,12,0"
                  VerticalAlignment="Center"
                  Text="{Binding SelectColor}"/>
                <fui:ColorPickerButton Grid.Column="1" Color="{Binding SelectedAccentColor}"/>
              </Grid>
            </fui:SettingsExpanderItem.Footer>
          </fui:SettingsExpanderItem>
        </fui:SettingsExpander>

        <fui:SettingCard
          Description="{Binding LanguageDescription}"
          Header="{Binding Language}"
          IconSource="{x:Static fi:FluentIcon.Language}">
          <ComboBox
            Width="128"
            HorizontalAlignment="Right"
            ItemsSource="{Binding Languages}"
            SelectedItem="{Binding CurrentLanguage}"/>
        </fui:SettingCard>

        <fui:SettingCard
          Description="{Binding PinToTopDescription}"
          Header="{Binding PinToTop}"
          IsEnabled="False">
          <ToggleSwitch IsChecked="False"/>
        </fui:SettingCard>

        <fui:SettingCard Description="{Binding EnableBackgroundImage}" Header="{Binding BackgroundImage}">
          <ToggleSwitch IsChecked="{Binding IsEnabledBackgroundImage}"/>
        </fui:SettingCard>

      </StackPanel>
    </fui:SmoothScrollViewer>
  </Grid>
</UserControl>
