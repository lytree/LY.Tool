-0.155 0.155-0.13 0.169-0.093 0.183-0.056 0.196-0.019z">
          <fui:SettingsExpanderItem Margin="-24,0,0,0">
            <StackPanel
              HorizontalAlignment="Left"
              Orientation="Vertical"
              Spacing="3">
              <RadioButton
                Command="{Binding ToggleThemeCommand}"
                CommandParameter="Light"
                Content="{Binding Light}"
                IsChecked="{Binding !IsDarkTheme}"/>
              <RadioButton
                Command="{Binding ToggleThemeCommand}"
                CommandParameter="Dark"
                Content="{Binding Dark}"
                IsChecked="{Binding IsDarkTheme}"/>
              <RadioButton
                Command="{Binding ToggleThemeCommand}"
                CommandParameter="Auto"
                Content="{Binding FollowSystem}"
                IsChecked="{Binding IsAutoTheme}"/>
            </StackPanel>
          </fui:SettingsExpanderItem>
        </fui:SettingsExpander>

        <fui:SettingsExpander
          Description="{Binding ThemeColorDescription}"
          Header="{Binding ThemeColor}"
