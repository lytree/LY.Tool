<UserControl
  x:Class="LYBox.Layout.Fluent.Views.SettingsView"
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:fi="clr-namespace:AvaloniaFluentUI.Icons;assembly=LYBox.Layout.Fluent"
  xmlns:fui="clr-namespace:AvaloniaFluentUI.Controls;assembly=LYBox.Layout.Fluent"
  xmlns:locale="clr-namespace:AvaloniaFluentUI.Locale;assembly=LYBox.Layout.Fluent"
  xmlns:ui="clr-namespace:LYBox.Layout.Fluent.Controls"
  xmlns:vm="clr-namespace:LYBox.Layout.Fluent.ViewModels"
  x:DataType="vm:SettingsViewModel">

  <UserControl.Styles>
    <Style Selector="ui|Card">
      <Setter Property="Padding" Value="10 10 15 10"/>
    </Style>

    <Style Selector="TextBlock.Title">
      <Setter Property="FontWeight" Value="Regular"/>
      <Setter Property="FontSize" Value="16"/>
    </Style>

    <Style Selector="TextBlock.Content">
      <Setter Property="FontSize" Value="12"/>
    </Style>
  </UserControl.Styles>

  <Grid
    Margin="10,20,0,0"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    RowDefinitions="64, *">
    <TextBlock
      Grid.Row="0"
      Margin="15,0,0,0"
      HorizontalAlignment="Left"
      FontSize="32"
      Text="{Binding Title}"/>
    <fui:SmoothScrollViewer Grid.Row="1" Padding="18,24,24,0">
      <StackPanel
        Margin="0,0,0,64"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        Orientation="Vertical"
        Spacing="10">

        <fui:SettingCard
          Description="{Binding WindowEffectDescription}"
          Header="{Binding WindowEffect}"
          IconSource="{x:Static fi:FluentIcon.Transparent}"
          IsEnabled="{Binding !IsEnabledBackgroundImage}">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <RadioButton
              Command="{Binding EnabledWindowEffectCommand}"
              CommandParameter="{Binding $self.Content}"
              Content="Null"
              IsChecked="{Binding !IsEnabledWindowEffect}"
              Theme="{StaticResource ChipsRadioButton}"/>
            <RadioButton
              Command="{Binding EnabledWindowEffectCommand}"
              CommandParameter="{Binding $self.Content}"
              Content="Mica"
              IsChecked="{Binding IsMicaRadioChecked}"
              IsEnabled="{Binding IsWindows11}"
              Theme="{StaticResource ChipsRadioButton}"/>
            <RadioButton
              Command="{Binding EnabledWindowEffectCommand}"
              CommandParameter="{Binding $self.Content}"
              Content="Acrylic"
              IsChecked="{Binding IsAcrylicRadioChecked}"
              IsEnabled="{Binding IsWindows}"
              Theme="{StaticResource ChipsRadioButton}"/>
          </StackPanel>
          <!-- <ToggleSwitch IsChecked="{Binding IsEnabledWindowEffect}"/> -->
        </fui:SettingCard>

        <fui:SettingsExpander
          Description="{Binding AppearanceDescription}"
          Header="{Binding AppThemeDescription}"
