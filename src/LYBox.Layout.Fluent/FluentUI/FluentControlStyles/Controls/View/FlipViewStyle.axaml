  <StreamGeometry x:Key="Next">M4 28.031v-24.063q0-0.828 0.32-1.547t0.859-1.258 1.266-0.852 1.555-0.313q1.234 0 2.281 0.719l15.141 10.406q1.219 0.844 1.898 2.125t0.68 2.75-0.68 2.75-1.898 2.125l-15.141 10.406q-1.047 0.719-2.281 0.719-0.828 0-1.555-0.313t-1.266-0.852-0.859-1.258-0.32-1.547z</StreamGeometry>
  <StreamGeometry x:Key="Up">M2.804 26.040q-0.589 0-1.098-0.232t-0.893-0.625-0.598-0.911-0.214-1.107q0-1.071 0.696-1.875l12.357-14.446q0.571-0.661 1.321-1.018t1.625-0.357q1.768 0 2.946 1.375l12.357 14.446q0.696 0.804 0.696 1.875 0 0.589-0.214 1.107t-0.598 0.911-0.893 0.625-1.098 0.232h-26.393z</StreamGeometry>
