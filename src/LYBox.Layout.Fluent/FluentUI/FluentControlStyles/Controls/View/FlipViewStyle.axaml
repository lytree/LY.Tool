  <ControlTheme x:Key="FlipViewButton" TargetType="Button">
    <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}"/>
    <Setter Property="BorderThickness" Value="{DynamicResource ButtonBorderThemeThickness}"/>
    <Setter Property="BackgroundSizing" Value="InnerBorderEdge"/>
    <Setter Property="Padding" Value="{StaticResource ButtonPadding}"/>
    <Setter Property="HorizontalAlignment" Value="Left"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}"/>
    <Setter Property="Template">
      <ControlTemplate>
        <Border
          Name="PART_Border"
          Width="{TemplateBinding Width}"
          Height="{TemplateBinding Height}"
          MinWidth="{TemplateBinding MinWidth}"
          MinHeight="{TemplateBinding MinHeight}"
          Padding="{TemplateBinding Padding}"
          HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
          VerticalAlignment="{TemplateBinding VerticalAlignment}"
          Background="{TemplateBinding Background}"
          BorderBrush="{TemplateBinding BorderBrush}"
          BorderThickness="{TemplateBinding BorderThickness}"
          CornerRadius="{TemplateBinding CornerRadius}">
          <Viewbox
            Name="IconViewBox"
            Width="10"
            Height="10"
            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
            VerticalAlignment="{TemplateBinding VerticalContentAlignment}">
            <Path
              Name="PART_Icon"
              Data="{TemplateBinding Content}"
              Fill="{TemplateBinding Foreground}"
              Stretch="Uniform"/>
          </Viewbox>
        </Border>
      </ControlTemplate>
    </Setter>

    <Style Selector="^ /template/ Border#PART_Border">
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="00:00:00.083"/>
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="^ /template/ Path#PART_Icon">
      <Setter Property="RenderTransformOrigin" Value="50%, 50%"/>
      <Setter Property="Transitions">
        <Transitions>
          <TransformOperationsTransition
            Easing="CubicEaseOut"
            Property="RenderTransform"
            Duration="0:0:0.15"/>
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="^:pointerover">
      <Style Selector="^ /template/ Border#PART_Border">
        <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}"/>
      </Style>
    </Style>

    <Style Selector="^:pressed">
      <Style Selector="^ /template/ Border#PART_Border">
        <Setter Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
      </Style>

      <Style Selector="^ /template/ Path#PART_Icon">
        <Setter Property="RenderTransform" Value="scale(0.7, 1.0)"/>
      </Style>
    </Style>

    <Style Selector="^:disabled">
      <Style Selector="^ /template/ Border#PART_Border">
        <Setter Property="Background" Value="{DynamicResource ControlFillColorDisabledBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
      </Style>

      <Style Selector="^ /template/ ui|FluentIconElement#PART_Icon">
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}"/>
      </Style>
    </Style>
  </ControlTheme>


  <ControlTheme x:Key="{x:Type ui:FlipView}" TargetType="ui:FlipView">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="ClipToBounds" Value="True"/>
    <Setter Property="Height" Value="520"/>
    <Setter Property="ImageInterpolationMode" Value="MediumQuality"/>
    <Setter Property="Stretch" Value="UniformToFill"/>

    <Setter Property="Template">
      <ControlTemplate>
        <Grid
          Margin="0"
          HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
          VerticalAlignment="{TemplateBinding VerticalAlignment}"
          RowDefinitions="*, Auto"
          RowSpacing="8">
          <Border
            Grid.Row="0"
            Background="{TemplateBinding Background}"
            BorderBrush="{TemplateBinding BorderBrush}"
            BorderThickness="{TemplateBinding BorderThickness}"
            ClipToBounds="{TemplateBinding ClipToBounds}"
            CornerRadius="{TemplateBinding CornerRadius}">
            <Panel>
              <Image
                Name="PART_CurrentImage"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Stretch="{TemplateBinding Stretch}"/>
              <Image
                Name="PART_NextImage"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                IsVisible="False"
                Stretch="{TemplateBinding Stretch}"/>
            </Panel>
          </Border>

          <Button
            Name="PART_PreviousButton"
            Width="20"
            Height="36"
            Margin="5,0,0,0"
            Padding="5"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Content="{StaticResource Previous}"
            IsVisible="False"
            Theme="{StaticResource FlipViewButton}"
            ZIndex="10"/>
          <Button
            Name="PART_NextButton"
            Width="20"
            Height="36"
            Margin="0,0,5,0"
            Padding="5"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Content="{StaticResource Next}"
            IsVisible="False"
            Theme="{StaticResource FlipViewButton}"
            ZIndex="10"/>

          <PipsPager
            Name="PART_PipsPager"
            Grid.Row="1"
            MinWidth="128"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Background="Transparent"
            BorderThickness="0"
            MaxVisiblePips="{TemplateBinding MaxVisiblePips}"
            NumberOfPages="{TemplateBinding ItemCount}"
            SelectedPageIndex="{Binding SelectedIndex, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>

          <!--  <ui:PipsPager  -->
          <!--  Name="PART_PipsPager"  -->
          <!--  Grid.Row="1"  -->
          <!--  MinWidth="128"  -->
          <!--  MaxWidth="256"  -->
          <!--  HorizontalAlignment="Center"  -->
          <!--  VerticalAlignment="Bottom"  -->
          <!--  Background="Transparent"  -->
          <!--  BorderThickness="0"  -->
          <!--  ItemsSource="{TemplateBinding ImageSource}"  -->
          <!--  ScrollViewer.BringIntoViewOnFocusChange="False"  -->
          <!--  SelectedIndex="{Binding SelectedIndex, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>  -->
        </Grid>
      </ControlTemplate>
    </Setter>

    <Style Selector="^[Orientation=Vertical]">
      <Style Selector="^ /template/ Button#PART_PreviousButton">
        <Setter Property="Width" Value="36"/>
        <Setter Property="Height" Value="20"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="Margin" Value="0 5 0 0"/>
        <Setter Property="Content" Value="{StaticResource Up}"/>
      </Style>

      <Style Selector="^ /template/ Button#PART_NextButton">
        <Setter Property="Width" Value="36"/>
        <Setter Property="Height" Value="20"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Bottom"/>
        <Setter Property="Margin" Value="0 0 0 5"/>
        <Setter Property="Content" Value="{StaticResource Down}"/>
      </Style>
    </Style>
  </ControlTheme>
</ResourceDictionary>
