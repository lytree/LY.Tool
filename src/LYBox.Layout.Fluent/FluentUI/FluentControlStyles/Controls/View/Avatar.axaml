<ResourceDictionary
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:ui="clr-namespace:AvaloniaFluentUI.Controls">
  <!--  Add Resources Here  -->
  <ControlTheme x:Key="{x:Type ui:Avatar}" TargetType="ui:Avatar">
    <Setter Property="Background" Value="{DynamicResource AvatarBackgroundDefaultBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
  </ControlTheme>
</ResourceDictionary>

