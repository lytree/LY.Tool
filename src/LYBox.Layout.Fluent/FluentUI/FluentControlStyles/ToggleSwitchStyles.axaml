<ResourceDictionary
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:locale="clr-namespace:AvaloniaFluentUI.Locale"
  x:CompileBindings="True">

  <Design.PreviewWith>
    <Border Padding="50">
      <StackPanel Spacing="5">
        <ToggleSwitch Content="Button"/>
      </StackPanel>
    </Border>
  </Design.PreviewWith>

  <Thickness x:Key="ToggleSwitchTopHeaderMargin">0,0,8,0</Thickness>
  <!--  Changed to GridLength  -->
  <GridLength x:Key="ToggleSwitchPreContentMargin">10</GridLength>
  <GridLength x:Key="ToggleSwitchPostContentMargin">10</GridLength>
  <!--  Not forced as of v2, but available if still wanted  -->
  <x:Double x:Key="ToggleSwitchThemeMinWidth">154</x:Double>


  <!--  Control-specific resources  -->
  <Thickness x:Key="ToggleSwitchOnStrokeThickness">0</Thickness>
  <Thickness x:Key="ToggleSwitchOuterBorderStrokeThickness">1</Thickness>

  <ControlTheme x:Key="{x:Type ToggleSwitch}" TargetType="ToggleSwitch">
    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
    <Setter Property="HorizontalAlignment" Value="Left"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
    <Setter Property="HorizontalContentAlignment" Value="Left"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}"/>

    <Setter Property="OffContent" Value="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[Off]}"/>
    <Setter Property="OnContent" Value="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[On]}"/>
    <Setter Property="KnobTransitions">
      <Transitions>
        <DoubleTransition
          Easing="0,0,0,1"
          Property="Canvas.Left"
          Duration="0:0:0.2"/>
      </Transitions>
    </Setter>
    <Setter Property="Template">
      <ControlTemplate>
        <Grid Background="{TemplateBinding Background}" ColumnDefinitions="Auto,*">

          <ContentPresenter
            x:Name="PART_ContentPresenter"
            Grid.Column="0"
            Margin="{DynamicResource ToggleSwitchTopHeaderMargin}"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Content="{TemplateBinding Content}"
            ContentTemplate="{TemplateBinding ContentTemplate}"
            IsVisible="{TemplateBinding Content,
                                        Converter={x:Static ObjectConverters.IsNotNull}}"/>

          <Grid
            Grid.Column="1"
            HorizontalAlignment="Left"
            VerticalAlignment="Top">

            <Grid.RowDefinitions>
              <RowDefinition Height="{DynamicResource ToggleSwitchPreContentMargin}"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="{DynamicResource ToggleSwitchPostContentMargin}"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="12" MaxWidth="12"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border
              x:Name="SwitchAreaGrid"
              Grid.RowSpan="3"
              Grid.ColumnSpan="3"
              Margin="0,5"
              Background="{DynamicResource SubtleFillColorTransparentBrush}"
              CornerRadius="{TemplateBinding CornerRadius}"
              TemplatedControl.IsTemplateFocusTarget="True"/>

            <ContentPresenter
              x:Name="PART_OffContentPresenter"
              Grid.RowSpan="3"
              Grid.Column="2"
              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
              Content="{TemplateBinding OffContent}"
              ContentTemplate="{TemplateBinding OffContentTemplate}"/>

            <ContentPresenter
              x:Name="PART_OnContentPresenter"
              Grid.RowSpan="3"
              Grid.Column="2"
              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
              Content="{TemplateBinding OnContent}"
              ContentTemplate="{TemplateBinding OnContentTemplate}"/>

            <Border
              x:Name="OuterBorder"
              Grid.Row="1"
              Width="40"
              Height="20"
              Background="{DynamicResource ControlAltFillColorSecondaryBrush}"
              BorderBrush="{DynamicResource ControlStrongFillColorDefaultBrush}"
              BorderThickness="{DynamicResource ToggleSwitchOuterBorderStrokeThickness}"
              CornerRadius="10">
              <Border.Transitions>
                <Transitions>
                  <BrushTransition Property="BorderBrush" Duration="00:00:00.167"/>
                  <BrushTransition Property="Background" Duration="00:00:00.167"/>
                </Transitions>
              </Border.Transitions>
            </Border>

            <Border
              x:Name="SwitchKnobBounds"
              Grid.Row="1"
              Width="40"
              Height="20"
              Background="{DynamicResource AccentFillColorDefaultBrush}"
              BorderBrush="{DynamicResource AccentFillColorDefaultBrush}"
              BorderThickness="{DynamicResource ToggleSwitchOnStrokeThickness}"
              CornerRadius="10">
              <Border.Transitions>
                <Transitions>
                  <BrushTransition Property="BorderBrush" Duration="00:00:00.167"/>
                  <BrushTransition Property="Background" Duration="00:00:00.167"/>
                </Transitions>
              </Border.Transitions>
            </Border>

            <Canvas
              x:Name="PART_SwitchKnob"
              Grid.Row="1"
              Width="20"
              Height="20"
              HorizontalAlignment="Left">

              <Grid
                x:Name="PART_MovingKnobs"
                Width="20"
                Height="20">

                <Ellipse
                  x:Name="SwitchKnobOn"
                  Width="12"
                  Height="12"
                  Fill="{DynamicResource TextOnAccentFillColorPrimaryBrush}">
                  <Ellipse.Transitions>
                    <Transitions>
                      <DoubleTransition
                        Easing="0,0 0,1"
                        Property="Width"
                        Duration="00:00:00.167"/>
                      <DoubleTransition
                        Easing="0,0 0,1"
                        Property="Height"
                        Duration="00:00:00.167"/>
                    </Transitions>
                  </Ellipse.Transitions>
                </Ellipse>

                <Ellipse
                  x:Name="SwitchKnobOff"
                  Width="12"
                  Height="12"
                  Fill="{DynamicResource TextFillColorSecondaryBrush}">
                  <Ellipse.Transitions>
                    <Transitions>
                      <DoubleTransition
                        Easing="0,0 0,1"
                        Property="Width"
                        Duration="00:00:00.167"/>
                      <DoubleTransition
                        Easing="0,0 0,1"
                        Property="Height"
                        Duration="00:00:00.167"/>
                    </Transitions>
                  </Ellipse.Transitions>
                </Ellipse>
              </Grid>
            </Canvas>
          </Grid>
        </Grid>
      </ControlTemplate>
    </Setter>


    <Style Selector="^:pointerover">
      <Style Selector="^ /template/ Border#OuterBorder">
        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrongFillColorDefaultBrush}"/>
        <Setter Property="Background" Value="{DynamicResource ControlAltFillColorTertiaryBrush}"/>
      </Style>
      <Style Selector="^ /template/ Ellipse#SwitchKnobOff">
        <Setter Property="Fill" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
        <Setter Property="Width" Value="14"/>
        <Setter Property="Height" Value="14"/>
      </Style>
      <Style Selector="^ /template/ Ellipse#SwitchKnobOn">
        <Setter Property="Fill" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}"/>
        <Setter Property="Width" Value="14"/>
        <Setter Property="Height" Value="14"/>
      </Style>
      <Style Selector="^ /template/ Border#SwitchKnobBounds">
        <Setter Property="Background" Value="{DynamicResource AccentFillColorSecondaryBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorSecondaryBrush}"/>
      </Style>
      <Style Selector="^ /template/ Border#SwitchAreaGrid">
        <Setter Property="Background" Value="{DynamicResource SubtleFillColorTransparentBrush}"/>
      </Style>
    </Style>

    <Style Selector="^:pressed">
      <Style Selector="^ /template/ Border#OuterBorder">
        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrongFillColorDefaultBrush}"/>
        <Setter Property="Background" Value="{DynamicResource ControlFillColorQuarternaryBrush}"/>
      </Style>
      <Style Selector="^ /template/ Border#SwitchKnobBounds">
        <Setter Property="Background" Value="{DynamicResource AccentFillColorTertiaryBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorTertiaryBrush}"/>
      </Style>
      <Style Selector="^ /template/ Ellipse#SwitchKnobOff">
        <Setter Property="Fill" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
        <Setter Property="Width" Value="17"/>
        <Setter Property="Height" Value="14"/>
      </Style>
      <Style Selector="^ /template/ Ellipse#SwitchKnobOn">
        <Setter Property="Fill" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}"/>
        <Setter Property="Width" Value="17"/>
        <Setter Property="Height" Value="14"/>
      </Style>
      <Style Selector="^ /template/ Border#SwitchAreaGrid">
        <Setter Property="Background" Value="{DynamicResource SubtleFillColorTransparentBrush}"/>
      </Style>
    </Style>

    <Style Selector="^:disabled">
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}"/>

      <Style Selector="^ /template/ Border#OuterBorder">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDisabledBrush}"/>
        <Setter Property="Background" Value="{DynamicResource ControlFillColorQuarternaryBrush}"/>
      </Style>
      <Style Selector="^ /template/ Ellipse#SwitchKnobOff">
        <Setter Property="Fill" Value="{DynamicResource TextFillColorDisabledBrush}"/>
      </Style>
      <Style Selector="^ /template/ Ellipse#SwitchKnobOn">
        <Setter Property="Fill" Value="{DynamicResource TextOnAccentFillColorDisabledBrush}"/>
      </Style>
      <Style Selector="^ /template/ Border#SwitchKnobBounds">
        <Setter Property="Background" Value="{DynamicResource AccentFillColorDisabledBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDisabledBrush}"/>
      </Style>
    </Style>


    <Style Selector="^:checked">
      <Style Selector="^ /template/ Border#OuterBorder">
        <Setter Property="Opacity" Value="0"/>
      </Style>
      <Style Selector="^ /template/ Ellipse#SwitchKnobOff">
        <Setter Property="Opacity" Value="0"/>
      </Style>
      <Style Selector="^ /template/ Border#SwitchKnobBounds">
        <Setter Property="Opacity" Value="1"/>
      </Style>
      <Style Selector="^ /template/ Ellipse#SwitchKnobOn">
        <Setter Property="Opacity" Value="1"/>
      </Style>
      <Style Selector="^ /template/ ContentPresenter#PART_OffContentPresenter">
        <Setter Property="Opacity" Value="0"/>
      </Style>
      <Style Selector="^ /template/ ContentPresenter#PART_OnContentPresenter">
        <Setter Property="Opacity" Value="1"/>
      </Style>
    </Style>

    <Style Selector="^:unchecked">
      <Style Selector="^ /template/ Border#OuterBorder">
        <Setter Property="Opacity" Value="1"/>
      </Style>

      <Style Selector="^ /template/ Ellipse#SwitchKnobOff">
        <Setter Property="Opacity" Value="1"/>
      </Style>

      <Style Selector="^ /template/ Ellipse#SwitchKnobOn">
        <Setter Property="Opacity" Value="0"/>
      </Style>

      <Style Selector="^  /template/ Border#SwitchKnobBounds">
        <Setter Property="Opacity" Value="0"/>
      </Style>

      <Style Selector="^ /template/ ContentPresenter#PART_OffContentPresenter">
        <Setter Property="Opacity" Value="1"/>
      </Style>

      <Style Selector="^ /template/ ContentPresenter#PART_OnContentPresenter">
        <Setter Property="Opacity" Value="0"/>
      </Style>
    </Style>
  </ControlTheme>
</ResourceDictionary>
