    <!--  VerticalAlignment="Center"  -->
    <!--  LetterSpacing="0"  -->
    <!--     LineSpacing="0"><Run Foreground="#e4c07b" Text="PathIcon"/><Run Foreground="#16b15e" Text="."/><Run Foreground="#ff7b7b" Text="Data"/><Run Foreground="#16b15e" Text=" = "/><Run Foreground="#e4c07b" Text="FluentIcon"/><Run Foreground="#16b15e" Text="."/><Run Foreground="#ff7b7b" Text="Accept"/> -->
    <!--   </SelectableTextBlock> -->
    <!-- </Border> -->

    <fui:SearchTextBox
      Grid.Row="4"
      Grid.ColumnSpan="2"
      Width="256"
      HorizontalAlignment="Left"
      PlaceholderText="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[IV_SearchIcon]}"
      TextChanged="OnSearchTextChanged"/>
    <fui:SmoothScrollViewer
      Grid.Row="5"
      Grid.Column="0"
      Margin="0,24,0,12"
      VerticalScrollBarVisibility="Visible">
      <UniformGrid
        x:Name="UniformGrid"
        Margin="0,0,15,0"
        VerticalAlignment="Top"
        ColumnSpacing="5"
        RowSpacing="5"/>
    </fui:SmoothScrollViewer>

    <StackPanel
      Grid.Row="5"
      Grid.Column="1"
      Margin="10,0,0,0"
      HorizontalAlignment="Left">
      <TextBlock
        FontSize="18"
        FontWeight="Bold"
        Text="{Binding CurrentIconName}"/>
      <PathIcon
        Width="64"
        Height="64"
        Margin="5,5,5,20"
        HorizontalAlignment="Left"
        Data="{Binding CurrentIconData, Mode=TwoWay}"/>
      <!--  Stretch="Uniform"  -->

      <TextBlock FontSize="16" Text="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[IV_IconName]}"/>
      <TextBlock FontSize="12" Text="{Binding CurrentIconName}"/>

      <TextBlock
        Margin="0,20,0,0"
        FontSize="16"
        Text="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[IV_EnumMember]}"/>
      <TextBlock FontSize="12" Text="{Binding CurrentItemEnumName}"/>
    </StackPanel>
  </Grid>
</UserControl>
