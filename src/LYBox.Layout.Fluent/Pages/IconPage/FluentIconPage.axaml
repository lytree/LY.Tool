    <!--  Height="35"  -->
    <!--  Padding="8"  -->
    <!--  Background="{DynamicResource AvatarBackgroundDefault}"  -->
    <!--  CornerRadius="6">  -->
    <!--   <SelectableTextBlock VerticalAlignment="Center"><Run Foreground="#e4c07b" Text="&lt;PathIcon"/><Run Foreground="#ff7b7b" Text=" Data"/><Run Foreground="#16b15e" Text="="/><Run Foreground="#16b15e">"{</Run><Run Foreground="#62bbc4" Text="x"/><Run Foreground="#16b15e" Text=":"/><Run Foreground="#e4c07b" Text="Static "/><Run Foreground="#62bbc4" Text="fi"/><Run Foreground="#16b15e" Text=":"/><Run Foreground="#e4c07b" Text="FluentIcon"/><Run Foreground="#16b15e" Text="."/><Run Foreground="#ff7b7b" Text="Accept"/><Run Foreground="#16b15e">}"</Run> -->
    <!--   </SelectableTextBlock> -->
    <!-- </Border> -->
    <!--    -->
    <!--  <TextBlock  -->
    <!--  Grid.Row="2"  -->
    <!--  Grid.ColumnSpan="2"  -->
    <!--  HorizontalAlignment="Left"  -->
    <!--  VerticalAlignment="Center"  -->
    <!--  Text="使用示例(C#)"/>  -->
    <!--  <Border  -->
    <!--  Grid.Row="3"  -->
    <!--  Grid.ColumnSpan="2"  -->
    <!--  Height="35"  -->
    <!--  Padding="8"  -->
    <!--  Background="{DynamicResource AvatarBackgroundDefault}"  -->
