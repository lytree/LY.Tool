<ui:ViewBase
  x:Class="LYBox.Layout.Fluent.Pages.TreeViewPage"
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:fi="clr-namespace:AvaloniaFluentUI.Icons;assembly=LYBox.Layout.Fluent"
  xmlns:fui="clr-namespace:AvaloniaFluentUI.Controls;assembly=LYBox.Layout.Fluent"
  xmlns:locale="clr-namespace:AvaloniaFluentUI.Locale;assembly=LYBox.Layout.Fluent"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="clr-namespace:LYBox.Layout.Fluent.Controls"
  xmlns:viewModel="clr-namespace:LYBox.Layout.Fluent.ViewModels"
  Title="{Binding Title}"
  d:DesignWidth="800"
  x:DataType="viewModel:TreeViewPageViewModel"
  mc:Ignorable="d">

  <ui:ViewBase.Styles>
    <Style Selector="TextBlock">
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
  </ui:ViewBase.Styles>

  <StackPanel Spacing="50">
    <ui:CodeCard
      Name="TreeViewCard"
      Title="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[VP_TreeView]}"
      Height="456">
      <Grid ColumnDefinitions="*, Auto">
        <TreeView ItemsSource="{Binding TreeViewItems}" SelectionMode="{Binding TreeViewSelectedMode}">
          <TreeView.ItemTemplate>
            <TreeDataTemplate x:DataType="viewModel:TreeViewPageViewModel+Node" ItemsSource="{Binding SubNodes}">
              <Border
                Padding="15,3"
                HorizontalAlignment="Left"
                CornerRadius="8">
                <TextBlock Text="{Binding Title}"/>
              </Border>
            </TreeDataTemplate>
          </TreeView.ItemTemplate>
        </TreeView>
        <ui:Card Grid.Column="1" Width="256">
          <StackPanel Orientation="Vertical" Spacing="3">
            <TextBlock Text="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[VP_Options]}"/>
            <StackPanel Orientation="Horizontal" Spacing="3">
              <TextBlock Text="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[VP_SelectMode]}"/>
              <ComboBox ItemsSource="{Binding TreeViewSelectedModes}" SelectedItem="{Binding TreeViewSelectedMode}"/>
            </StackPanel>
          </StackPanel>
        </ui:Card>
      </Grid>
    </ui:CodeCard>
  </StackPanel>
</ui:ViewBase>
