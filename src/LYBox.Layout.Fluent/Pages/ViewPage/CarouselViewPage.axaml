<ui:ViewBase
  x:Class="LYBox.Layout.Fluent.Pages.CarouselViewPage"
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:fi="clr-namespace:AvaloniaFluentUI.Icons;assembly=LYBox.Layout.Fluent"
  xmlns:fui="clr-namespace:AvaloniaFluentUI.Controls;assembly=LYBox.Layout.Fluent"
  xmlns:locale="clr-namespace:AvaloniaFluentUI.Locale;assembly=LYBox.Layout.Fluent"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:models="clr-namespace:LYBox.Layout.Fluent.Models"
  xmlns:ui="clr-namespace:LYBox.Layout.Fluent.Controls"
  xmlns:viewModel="clr-namespace:LYBox.Layout.Fluent.ViewModels"
  Title="{Binding Title}"
  d:DesignWidth="800"
  x:DataType="viewModel:CarouselViewPageViewModel"
  mc:Ignorable="d">

  <ui:ViewBase.Styles>
    <Style Selector="TextBlock">
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
  </ui:ViewBase.Styles>

  <StackPanel Spacing="50">
    <ui:CodeCard
      Name="PageTransitionsCard"
      Title="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[VP_Carousel]}"
      Height="400">
      <Grid ColumnDefinitions="*, Auto">
        <Carousel
          Name="Carousel"
          Margin="0,0,15,0"
          AutoScrollToSelectedItem="True"
          ItemsSource="{Binding CarouselItems}"
          SelectedIndex="{Binding CarouselCurrentIndex}"
          WrapSelection="True">
          <Carousel.PageTransition>
            <CompositePageTransition>
              <PageSlide
                Orientation="Horizontal"
                SlideInEasing="CubicEaseOut"
                Duration="0:0:0.30"/>
            </CompositePageTransition>
          </Carousel.PageTransition>
          <Carousel.ItemTemplate>
            <DataTemplate DataType="models:CarouselData">
              <Border
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="{Binding Background}"
                CornerRadius="8">
                <TextBlock
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  FontSize="24"
                  Text="{Binding Content}"/>
              </Border>
            </DataTemplate>
          </Carousel.ItemTemplate>
        </Carousel>

        <ui:Card Grid.Column="1" Width="256">
          <StackPanel Orientation="Vertical" Spacing="8">
            <TextBlock FontWeight="Bold" Text="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[VP_Options]}"/>
            <TextBlock Text="{Binding CarouselAllCountFormat}"/>
            <TextBlock Text="{Binding CarouselCurrentIndexFormat}"/>
            <Button
              HorizontalAlignment="Stretch"
              Command="{Binding #Carousel.Previous}"
              Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[VP_Previous]}"/>
            <Button
              HorizontalAlignment="Stretch"
              Command="{Binding #Carousel.Next}"
              Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[VP_Next]}"/>
            <Button
              HorizontalAlignment="Stretch"
              Classes="Accent"
              Command="{Binding AddCarouselCommand}"
              Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[VP_AddPage]}"/>
            <CheckBox Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[VP_AutoPlay]}" IsChecked="{Binding IsAutoPlay}"/>
          </StackPanel>
        </ui:Card>
      </Grid>
    </ui:CodeCard>

    <ui:CodeCard Name="FlipViewCard" Title="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[FlipView]}">
      <Grid ColumnDefinitions="*, Auto">
        <fui:FlipView
          Height="400"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch"
          DecodeToHeight="800"
          ImageSource="{Binding FlipViewItems}"
          Interval="{Binding FlipViewAutoPlayInterval}"
          IsAutoPlay="{Binding FlipViewIsAutoPlay, Mode=TwoWay}"
          MaxVisiblePips="{Binding FlipViewMaxVisiblePips}"
          Orientation="{Binding CurrentFlipOrientation}"
          SelectedIndex="0"/>
        <ui:Card
          Grid.Column="1"
          Width="256"
          Margin="10,0,0,0">

          <Grid
            ColumnDefinitions="Auto, *"
            ColumnSpacing="5"
            RowDefinitions="Auto, Auto, Auto, Auto, Auto"
            RowSpacing="6">
            <TextBlock
              Grid.Row="0"
              Grid.ColumnSpan="2"
              Text="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[VP_Options]}"/>

            <!--  IsAutoPlay  -->
            <CheckBox
              Grid.Row="1"
              Grid.ColumnSpan="2"
              HorizontalAlignment="Left"
              Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[VP_AutoPlay]}"
              IsChecked="{Binding FlipViewIsAutoPlay}"/>

            <!--  Interval  -->
            <TextBlock
              Grid.Row="2"
              Grid.Column="0"
              VerticalAlignment="Center"
              Text="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[VP_Interval]}"/>
            <ComboBox
              Grid.Row="2"
              Grid.Column="1"
              MinWidth="150"
              HorizontalAlignment="Stretch"
              ItemsSource="{Binding Intervals}"
              SelectedItem="{Binding FlipViewAutoPlayInterval}"/>

            <!--  Orientation  -->
            <TextBlock
              Grid.Row="3"
              Grid.Column="0"
              VerticalAlignment="Center"
              Text="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[VP_Direction]}"/>
            <ComboBox
              Grid.Row="3"
              Grid.Column="1"
              MinWidth="150"
              HorizontalAlignment="Stretch"
              ItemsSource="{Binding FlipOrientations}"
              SelectedItem="{Binding CurrentFlipOrientation}"/>

            <TextBlock
              Grid.Row="4"
              Grid.Column="0"
              VerticalAlignment="Center"
              Text="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[VP_PipsCount]}"/>
            <ComboBox
              Grid.Row="4"
              Grid.Column="1"
              MinWidth="150"
              HorizontalAlignment="Stretch"
              ItemsSource="{Binding FlipViewMaxVisiblePipsItems}"
              SelectedItem="{Binding FlipViewMaxVisiblePips}"/>
          </Grid>
        </ui:Card>
      </Grid>
    </ui:CodeCard>

  </StackPanel>
</ui:ViewBase>
