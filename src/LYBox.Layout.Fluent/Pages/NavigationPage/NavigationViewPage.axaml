          </fui:NavigationView.MenuItems>

          <fui:NavigationView.Content>
            <TextBlock
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              FontSize="24"
              Text="{Binding NavigationCurrentItemFormat}"
              TextAlignment="Center"/>
          </fui:NavigationView.Content>
        </fui:NavigationView>

        <ui:Card Grid.Column="1">
          <Grid
            ColumnDefinitions="Auto, *"
            ColumnSpacing="5"
            RowDefinitions="Auto, Auto, Auto, Auto"
            RowSpacing="3">
            <TextBlock
              Grid.Row="0"
              Grid.ColumnSpan="2"
              FontWeight="Bold"
              Text="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[BI_Options]}"/>

            <TextBlock
              Grid.Row="1"
              Grid.Column="0"
              Text="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[NV_DisplayMode]}"/>
            <ComboBox
              Grid.Row="1"
              Grid.Column="1"
              HorizontalAlignment="Stretch"
              ItemsSource="{Binding DisplayModes}"
              SelectedItem="{Binding CurrentDisplayMode}"/>

            <TextBlock
              Grid.Row="2"
              Grid.Column="0"
              Text="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[NV_PaneDisplayMode]}"/>
            <ComboBox
              Grid.Row="2"
              Grid.Column="1"
              HorizontalAlignment="Stretch"
              ItemsSource="{Binding PaneDisplayModes}"
              SelectedItem="{Binding CurrentPaneDisplayMode}"/>
            <CheckBox
              Grid.Row="3"
              Grid.ColumnSpan="2"
              Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[NV_ShowBackButton]}"
              IsChecked="{Binding BackButtonIsEnabled}"/>
          </Grid>
        </ui:Card>
      </Grid>
    </ui:CodeCard>
  </StackPanel>
</ui:ViewBase>
