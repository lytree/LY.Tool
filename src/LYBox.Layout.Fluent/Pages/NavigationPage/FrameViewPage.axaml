<ui:ViewBase
  x:Class="LYBox.Layout.Fluent.Pages.FrameViewPage"
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:fi="clr-namespace:AvaloniaFluentUI.Icons;assembly=LYBox.Layout.Fluent"
  xmlns:fui="clr-namespace:AvaloniaFluentUI.Controls;assembly=LYBox.Layout.Fluent"
  xmlns:locale="clr-namespace:AvaloniaFluentUI.Locale;assembly=LYBox.Layout.Fluent"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:ui="clr-namespace:LYBox.Layout.Fluent.Controls"
  xmlns:viewModel="clr-namespace:LYBox.Layout.Fluent.ViewModels"
  Title="{Binding Title}"
  d:DesignWidth="800"
  x:DataType="viewModel:FrameViewPageViewModel"
  mc:Ignorable="d">

  <ui:ViewBase.Styles>
    <Style Selector="TextBlock">
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
  </ui:ViewBase.Styles>

  <StackPanel Spacing="50">
    <ui:CodeCard Title="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[Frame]}">
      <Grid ColumnDefinitions="*, Auto">
        <StackPanel Focusable="False" Orientation="Vertical">
          <ListBox Focusable="False" SelectionChanged="OnListSelectionChanged">
            <ListBox.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel Focusable="False"/>
              </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.Items>
              <ListBoxItem Content="Page 1"/>
              <ListBoxItem Content="Page 2"/>
              <ListBoxItem Content="Page 3"/>
              <ListBoxItem Content="Page 4"/>
            </ListBox.Items>
          </ListBox>
          <ui:Card Height="328" HorizontalAlignment="Stretch">
            <fui:Frame Name="Frame" Focusable="False"/>
          </ui:Card>
        </StackPanel>

        <ui:Card Grid.Column="1" Width="256">
          <StackPanel Orientation="Vertical" Spacing="5">
            <Button
              HorizontalAlignment="Stretch"
              Command="{Binding #Frame.GoBack}"
              Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Back]}"
              IsEnabled="{Binding #Frame.CanGoBack}"/>
            <Button
              HorizontalAlignment="Stretch"
              Command="{Binding #Frame.GoForward}"
              Content="{Binding Source={x:Static locale:LocalizationService.Instance}, Path=[MT_Forward]}"
              IsEnabled="{Binding #Frame.CanGoForward}"/>
          </StackPanel>
        </ui:Card>
      </Grid>
    </ui:CodeCard>

  </StackPanel>
</ui:ViewBase>
