<ResourceDictionary
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="clr-namespace:LYBox.Layout.Fluent.Controls">

  <ControlTheme x:Key="{x:Type controls:LinkCard}" TargetType="controls:LinkCard">
    <Setter Property="Background" Value="{DynamicResource LinkCardBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource LinkCardBorderBrush}"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Width" Value="198"/>
    <Setter Property="Height" Value="220"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Template">
      <ControlTemplate>
        <Border
          Name="Border"
          Width="{TemplateBinding Width}"
          Height="{TemplateBinding Height}"
          Background="{TemplateBinding Background}"
          BorderBrush="{TemplateBinding BorderBrush}"
          BorderThickness="{TemplateBinding BorderThickness}"
          CornerRadius="8">
          <Grid Margin="20,20,10,10" RowDefinitions="Auto, Auto, *, Auto">
            <PathIcon
              Grid.Row="0"
              Width="64"
              Height="64"
              HorizontalAlignment="Left"
              Data="{TemplateBinding IconData}"/>
            <TextBlock
              Grid.Row="1"
              Margin="0,8,0,0"
              FontSize="18"
              Text="{TemplateBinding Title}"/>
            <TextBlock
              Grid.Row="2"
              Margin="0,8,0,8"
              FontSize="13"
              Text="{TemplateBinding Content}"
              TextWrapping="WrapWithOverflow"/>
            <PathIcon
              Grid.Row="3"
              Width="16"
              Height="16"
              HorizontalAlignment="Right"
              VerticalAlignment="Bottom"
