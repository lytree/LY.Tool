    <Style Selector="^:pointerover /template/ Border#Border">
      <Setter Property="Background" Value="{DynamicResource LinkCardBrushPointerOver}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource LinkCardBorderBrushPointerOver}"/>
    </Style>
  </ControlTheme>
</ResourceDictionary>