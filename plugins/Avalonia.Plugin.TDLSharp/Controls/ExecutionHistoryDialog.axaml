<UserControl
    x:Class="Avalonia.Plugin.TDLSharp.Controls.ExecutionHistoryDialog"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:Avalonia.Plugin.TDLSharp.Models"
    xmlns:vm="clr-namespace:Avalonia.Plugin.TDLSharp.ViewModels"
    d:DesignHeight="480"
    d:DesignWidth="720"
    x:DataType="vm:ExecutionHistoryDialogViewModel"
    Loaded="OnLoaded"
    mc:Ignorable="d">

    <Grid Margin="16" RowDefinitions="Auto,*">

        <!-- 标题行 + 操作按钮 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0 0 0 12">
            <TextBlock
                VerticalAlignment="Center"
                FontSize="15"
                FontWeight="600"
                Text="{DynamicResource LBL_ExecutionHistory}" />
            <Button
                Command="{Binding ApplyParametersCommand}"
                CommandParameter="{Binding SelectedRecord}"
                Content="{DynamicResource BTN_ApplySelected}"
                FontSize="12"
                Padding="10 4" />
            <Button
                Command="{Binding DeleteRecordCommand}"
                CommandParameter="{Binding SelectedRecord}"
                Content="{DynamicResource BTN_DeleteSelected}"
                FontSize="12"
                Padding="10 4" />
            <Button
                Command="{Binding ClearAllCommand}"
                Content="{DynamicResource BTN_ClearAll}"
                FontSize="12"
                Padding="10 4" />
        </StackPanel>

        <!-- 表格展示 -->
        <DataGrid
            x:Name="HistoryDataGrid"
            Grid.Row="1"
            AutoGenerateColumns="False"
            CanUserReorderColumns="True"
            CanUserResizeColumns="True"
            CanUserSortColumns="True"
            GridLinesVisibility="Horizontal"
            HeadersVisibility="Column"
            IsReadOnly="True"
            ItemsSource="{Binding Records}"
            SelectedItem="{Binding SelectedRecord}"
            SelectionMode="Single"
            DoubleTapped="DataGrid_DoubleTapped"
            ScrollViewer.VerticalScrollBarVisibility="Auto"
            ScrollViewer.HorizontalScrollBarVisibility="Auto">
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding StatusIcon}" Header="{DynamicResource LBL_Status}" Width="50" />
                <DataGridTextColumn Binding="{Binding ParameterSummary}" Header="{DynamicResource LBL_Parameters}" Width="*" />
                <DataGridTextColumn Binding="{Binding Status}" Header="{DynamicResource LBL_Result}" Width="60" />
                <DataGridTextColumn Binding="{Binding ExecutedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" Header="{DynamicResource LBL_ExecutedAt}" Width="140" />
                <DataGridTextColumn Binding="{Binding DurationText}" Header="{DynamicResource LBL_Duration}" Width="70" />
                <DataGridTemplateColumn Header="{DynamicResource LBL_Actions}" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:ExecutionHistoryRecord">
                            <Button
                                Content="{DynamicResource BTN_Delete}"
                                FontSize="11"
                                Padding="4 2"
                                Command="{Binding $parent[DataGrid].((vm:ExecutionHistoryDialogViewModel)DataContext).DeleteRecordCommand}"
                                CommandParameter="{Binding}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Command="{Binding $parent[DataGrid].((vm:ExecutionHistoryDialogViewModel)DataContext).ApplyParametersCommand}" CommandParameter="{Binding $parent[DataGrid].SelectedItem}" Header="{DynamicResource MENU_ApplyToInput}" />
                    <MenuItem Command="{Binding $parent[DataGrid].((vm:ExecutionHistoryDialogViewModel)DataContext).DeleteRecordCommand}" CommandParameter="{Binding $parent[DataGrid].SelectedItem}" Header="{DynamicResource MENU_DeleteRecord}" />
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>

    </Grid>
</UserControl>
