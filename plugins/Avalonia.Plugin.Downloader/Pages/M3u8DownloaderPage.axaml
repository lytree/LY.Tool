<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="clr-namespace:Avalonia.Plugin.Downloader.ViewModels"
			 xmlns:models="clr-namespace:Avalonia.Plugin.Downloader.Models"
			 x:Class="Avalonia.Plugin.Downloader.Pages.M3u8DownloaderPage"
			 x:DataType="vm:M3u8DownloaderViewModel"
			 mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="700">
	<ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
		<StackPanel Margin="16" Spacing="12">

			<StackPanel Spacing="4" Margin="0 0 0 4">
				<TextBlock Text="{Binding Script.Name}" Theme="{StaticResource TitleTextBlock}" Classes="H3" />
				<TextBlock Text="{Binding Script.Description}" Classes="Secondary" />
			</StackPanel>

			<Border Theme="{DynamicResource CardBorder}" Padding="16">
				<StackPanel Spacing="12">
					<TextBlock Text="{DynamicResource LBL_DownloadLinks}" Classes="SectionTitle" />

					<Grid ColumnDefinitions="*,160" Margin="0 0 0 4">
						<TextBlock Grid.Column="0" Text="{DynamicResource LBL_M3u8UrlList}" Classes="Body" VerticalAlignment="Center" />
						<Button Grid.Column="1" Content="{DynamicResource BTN_AddLink}" Command="{Binding AddUrlEntryCommand}" Theme="{DynamicResource SolidButton}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
					</Grid>

					<ItemsControl ItemsSource="{Binding UrlEntries}">
						<ItemsControl.DataTemplates>
							<DataTemplate x:DataType="models:M3u8UrlEntry">
								<Grid ColumnDefinitions="*,200,32" Margin="0 4" MinHeight="32">
									<TextBox Grid.Column="0"
											 Text="{Binding Url}"
											 PlaceholderText="{DynamicResource HINT_InputM3u8Url}"
											 HorizontalAlignment="Stretch"
											 Margin="0 0 8 0" />
									<TextBox Grid.Column="1"
											 Text="{Binding FileName}"
											 PlaceholderText="{DynamicResource HINT_FileNameOptional}"
											 HorizontalAlignment="Stretch"
											 Margin="0 0 8 0" />
									<Button Grid.Column="2"
											Content="✕"
											Command="{Binding $parent[ItemsControl].((vm:M3u8DownloaderViewModel)DataContext).RemoveUrlEntryCommand}"
											CommandParameter="{Binding}"
											Theme="{DynamicResource SolidButton}" Classes="Danger Small"
											VerticalAlignment="Center"
											HorizontalAlignment="Center"
											Padding="4"
											FontSize="14" />
								</Grid>
							</DataTemplate>
						</ItemsControl.DataTemplates>
					</ItemsControl>
				</StackPanel>
			</Border>

			<Border Theme="{DynamicResource CardBorder}" Padding="16">
				<StackPanel Spacing="12">
					<TextBlock Text="{DynamicResource LBL_SaveSettings}" Classes="SectionTitle" />

					<Grid ColumnDefinitions="160,*,160" Margin="0 4" MinHeight="32">
						<TextBlock Grid.Column="0" Text="{DynamicResource LBL_SavePath}" VerticalAlignment="Center" Classes="Body" />
						<TextBox Grid.Column="1"
								 Text="{Binding SavePath}"
								 PlaceholderText="{DynamicResource HINT_SelectSaveFolder}"
								 HorizontalAlignment="Stretch"
								 IsReadOnly="True"
								 Margin="0 0 8 0" />
						<Button Grid.Column="2"
								Content="{DynamicResource BTN_Browse}"
								Command="{Binding BrowseSavePathCommand}"
								Theme="{DynamicResource SolidButton}" Classes="Small"
								VerticalAlignment="Center"
								HorizontalAlignment="Stretch"
								HorizontalContentAlignment="Center" />
					</Grid>
				</StackPanel>
			</Border>

			<Border Theme="{DynamicResource CardBorder}" Padding="16">
				<StackPanel Spacing="12">
					<TextBlock Text="{DynamicResource LBL_ParameterConfig}" Classes="SectionTitle" />
					<ItemsControl ItemsSource="{Binding Parameters}">
						<ItemsControl.DataTemplates>
							<DataTemplate x:DataType="models:TextScriptParameter">
								<Grid ColumnDefinitions="160,*" Margin="0 4" MinHeight="32">
									<TextBlock Grid.Column="0" Text="{Binding DisplayName}" VerticalAlignment="Center" Classes="Body" />
									<TextBox Grid.Column="1" Text="{Binding DefaultValue}" PlaceholderText="{Binding Description}" HorizontalAlignment="Stretch" />
								</Grid>
							</DataTemplate>
							<DataTemplate x:DataType="models:BoolScriptParameter">
								<Grid ColumnDefinitions="160,*" Margin="0 4" MinHeight="32">
									<TextBlock Grid.Column="0" Text="{Binding DisplayName}" VerticalAlignment="Center" Classes="Body" />
									<ToggleSwitch Grid.Column="1" IsChecked="{Binding DefaultBoolValue}" OnContent="{DynamicResource SW_On}" OffContent="{DynamicResource SW_Off}" />
								</Grid>
							</DataTemplate>
							<DataTemplate x:DataType="models:NumberScriptParameter">
								<Grid ColumnDefinitions="160,*" Margin="0 4" MinHeight="32">
									<TextBlock Grid.Column="0" Text="{Binding DisplayName}" VerticalAlignment="Center" Classes="Body" />
									<NumericUpDown Grid.Column="1" Value="{Binding DefaultIntValue}" Minimum="0" HorizontalAlignment="Stretch" />
								</Grid>
							</DataTemplate>
							<DataTemplate x:DataType="models:PathScriptParameter">
								<Grid ColumnDefinitions="160,*,160" Margin="0 4" MinHeight="32">
									<TextBlock Grid.Column="0" Text="{Binding DisplayName}" VerticalAlignment="Center" Classes="Body" />
									<TextBox Grid.Column="1"
											 Text="{Binding DefaultValue}"
											 PlaceholderText="{Binding Description}"
											 HorizontalAlignment="Stretch"
											 IsReadOnly="True" />
									<Button Grid.Column="2"
										Content="{DynamicResource BTN_Browse}" Command="{Binding BrowseCommand}"
										Theme="{DynamicResource SolidButton}" Classes="Small"
										VerticalAlignment="Center" Margin="8,0,0,0" />
								</Grid>
							</DataTemplate>
						</ItemsControl.DataTemplates>
					</ItemsControl>

					<StackPanel Orientation="Horizontal" Spacing="12" Margin="0 8 0 0">
						<Button Content="{DynamicResource BTN_Execute}" Command="{Binding ExecuteScriptCommand}" Theme="{DynamicResource SolidButton}" Classes="Primary" MinWidth="100" IsEnabled="{Binding !IsRunning}" />
						<Button Content="{DynamicResource BTN_Cancel}" Command="{Binding CancelExecutionCommand}" Theme="{DynamicResource SolidButton}" MinWidth="80" IsVisible="{Binding IsRunning}" />
						<TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Classes="Tertiary" Margin="12 0 0 0" />
					</StackPanel>
				</StackPanel>
			</Border>

			<Border Theme="{DynamicResource CardBorder}" Padding="12" MaxHeight="{Binding LogMaxHeight}">
				<Grid RowDefinitions="Auto,*">
					<Grid ColumnDefinitions="*,Auto" Margin="0 0 0 8">
						<TextBlock Grid.Column="0" Text="{DynamicResource LBL_LogOutput}" Classes="SectionTitle" VerticalAlignment="Center" />
						<Button Grid.Column="1" Content="{DynamicResource BTN_Clear}" Command="{Binding ClearLogCommand}" Theme="{DynamicResource SolidButton}" Classes="Small" FontSize="12" Padding="8 4" />
					</Grid>
					<ListBox x:Name="LogListBox" Grid.Row="1"
							 ItemsSource="{Binding LogEntries}"
							 SelectionMode="Toggle"
							 ScrollViewer.VerticalScrollBarVisibility="Auto"
							 ScrollViewer.HorizontalScrollBarVisibility="Auto">
						<ListBox.Styles>
							<Style Selector="ListBoxItem">
								<Setter Property="Padding" Value="2 1" />
								<Setter Property="HorizontalContentAlignment" Value="Stretch" />
							</Style>
						</ListBox.Styles>
						<ListBox.ItemTemplate>
							<DataTemplate x:DataType="models:LogEntry">
								<SelectableTextBlock Text="{Binding FormattedLine}" FontSize="12" FontFamily="Consolas" TextWrapping="Wrap">
									<SelectableTextBlock.ContextMenu>
										<ContextMenu x:CompileBindings="False">
											<MenuItem Header="{DynamicResource MENU_COPY}" Command="{Binding $parent[ListBox].DataContext.CopyLogEntryCommand}" CommandParameter="{Binding}" />
										</ContextMenu>
									</SelectableTextBlock.ContextMenu>
								</SelectableTextBlock>
							</DataTemplate>
						</ListBox.ItemTemplate>
					</ListBox>
				</Grid>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>
