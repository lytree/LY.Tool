<UserControl
    x:Class="Avalonia.Plugin.ProDataGrid.Pages.CustomDrawingLiveUpdatesPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Avalonia.Plugin.ProDataGrid.ViewModels"
    xmlns:customDrawing="clr-namespace:Avalonia.Plugin.ProDataGrid.CustomDrawing"
    x:DataType="vm:CustomDrawingLiveUpdatesViewModel"
    x:CompileBindings="True"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

  <UserControl.Resources>
    <customDrawing:SkiaAnimatedTextCellDrawOperationFactory x:Key="LiveSkiaFactory"
                                                             Padding="4,2,4,2"
                                                             TextAlignment="Left"
                                                             VerticalAlignment="Center"
                                                             WaveAmplitude="1.8" />
  </UserControl.Resources>

  <Grid RowDefinitions="Auto,Auto,*" RowSpacing="12" Margin="12">
    <StackPanel Spacing="4">
      <TextBlock Classes="h2" Text="{DynamicResource TITLE_CustomDrawingLive}" />
      <TextBlock Text="{DynamicResource DESC_CustomDrawingLive}"
                 TextWrapping="Wrap" />
    </StackPanel>

    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
      <Button Content="{DynamicResource BTN_Start}" Command="{Binding StartCommand}" />
      <Button Content="{DynamicResource BTN_Stop}" Command="{Binding StopCommand}" />
      <Button Content="{DynamicResource BTN_ResetData}" Command="{Binding ResetRowsCommand}" />
      <TextBlock Text="{DynamicResource LBL_IntervalMs}" VerticalAlignment="Center" />
      <TextBox Width="72" Text="{Binding IntervalMs, UpdateSourceTrigger=PropertyChanged}" />
      <TextBlock Text="{Binding FrameCountText}" VerticalAlignment="Center" />
      <TextBlock Text="{Binding RunStateText}" VerticalAlignment="Center" />
    </StackPanel>

    <DataGrid Grid.Row="2"
              ItemsSource="{Binding Rows}"
              AutoGenerateColumns="False"
              CanUserAddRows="False"
              CanUserReorderColumns="True"
              CanUserResizeColumns="True"
              CanUserSortColumns="True"
              IsReadOnly="True"
              RowHeight="28"
              GridLinesVisibility="Horizontal"
              RowBackground="#08000000"
              x:CompileBindings="False">
      <DataGrid.Columns>
        <DataGridTextColumn Header="{DynamicResource COL_ID}"
                            Binding="{Binding Id}"
                            Width="90"
                            x:DataType="vm:CustomDrawingLiveUpdatesRow" />

        <DataGridTextColumn Header="{DynamicResource COL_Symbol}"
                            Binding="{Binding Symbol}"
                            Width="120"
                            x:DataType="vm:CustomDrawingLiveUpdatesRow" />

        <DataGridCustomDrawingColumn Header="{DynamicResource COL_AnimatedMessage}"
                                     Binding="{Binding Message}"
                                     Width="*"
                                     DrawingMode="DrawOperation"
                                     RenderBackend="CompositionCustomVisual"
                                     DrawOperationFactory="{StaticResource LiveSkiaFactory}"
                                     TextLayoutCacheMode="Shared"
                                     SharedTextLayoutCacheCapacity="1024"
                                     DrawOperationLayoutFastPath="False"
                                     Foreground="{DynamicResource ThemeForegroundBrush}"
                                     x:DataType="vm:CustomDrawingLiveUpdatesRow" />
      </DataGrid.Columns>
    </DataGrid>
  </Grid>
</UserControl>
