<UserControl
    x:Class="Avalonia.Plugin.ProDataGrid.Pages.RowDetailsSelectionDemo"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Avalonia.Plugin.ProDataGrid.ViewModels"
    xmlns:models="clr-namespace:Avalonia.Plugin.ProDataGrid.Models"
    x:DataType="vm:RowDetailsSelectionDemoViewModel"
    x:CompileBindings="True"
    d:DesignHeight="600"
    d:DesignWidth="900"
    mc:Ignorable="d">
    <Grid RowDefinitions="Auto, Auto, Auto, *">
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <Button Content="添加员工" Command="{Binding AddEmployeeCommand}" />
            <Button Content="删除选中" Command="{Binding RemoveSelectedCommand}" />
            <Button Content="重置数据" Command="{Binding ResetDataCommand}" />
            <Button Content="切换详情" Command="{Binding ToggleDetailsVisibilityCommand}" />
            <Button Content="保存" Command="{Binding SaveCommand}" />
        </StackPanel>
        <TextBlock Grid.Row="1" Text="{Binding SelectionInfo}" FontWeight="SemiBold" Margin="0,0,0,8" />
        <TextBlock Grid.Row="2" Text="演示：行详情模板、选中模式、SelectedItem 绑定、行详情可见性切换" Opacity="0.6" Margin="0,0,0,8" />
        <DataGrid
            Grid.Row="3"
            ItemsSource="{Binding Employees}"
            SelectedItem="{Binding SelectedEmployee}"
            AutoGenerateColumns="False"
            CanUserResizeColumns="True"
            CanUserReorderColumns="True"
            CanUserSortColumns="True"
            SelectionMode="Extended"
            GridLinesVisibility="All"
            HeadersVisibility="All"
            IsReadOnly="False"
            EditTriggers="CellClick,CellDoubleClick,F2,TextInput"
            AreRowDetailsFrozen="True"
            RowDetailsVisibilityMode="VisibleWhenSelected"
            x:CompileBindings="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id, Mode=OneWay}" Width="60" IsReadOnly="True" />
                <DataGridTextColumn Header="名" Binding="{Binding FirstName, Mode=TwoWay}" Width="*" />
                <DataGridTextColumn Header="姓" Binding="{Binding LastName, Mode=TwoWay}" Width="*" />
                <DataGridCheckBoxColumn Header="在职" Binding="{Binding IsActive, Mode=TwoWay}" Width="80" />
                <DataGridTextColumn Header="部门" Binding="{Binding Department, Mode=TwoWay}" Width="*" />
                <DataGridTextColumn Header="职位" Binding="{Binding Position, Mode=TwoWay}" Width="*" />
                <DataGridTextColumn Header="薪资" Binding="{Binding Salary, Mode=TwoWay}" Width="100" />
                <DataGridTextColumn Header="城市" Binding="{Binding City, Mode=TwoWay}" Width="100" />
            </DataGrid.Columns>
            <DataGrid.RowDetailsTemplate>
                <DataTemplate x:DataType="models:Employee">
                    <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}" Padding="16" Margin="4">
                        <Grid ColumnDefinitions="Auto, *, Auto, *" RowDefinitions="Auto, Auto, Auto, Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="姓名：" FontWeight="SemiBold" Margin="0,0,8,4" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding FullName}" Margin="0,0,16,4" />
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="邮箱：" FontWeight="SemiBold" Margin="0,0,8,4" />
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding Email}" Margin="0,0,0,4" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="部门：" FontWeight="SemiBold" Margin="0,0,8,4" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Department}" Margin="0,0,16,4" />
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="职位：" FontWeight="SemiBold" Margin="0,0,8,4" />
                            <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding Position}" Margin="0,0,0,4" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="入职日期：" FontWeight="SemiBold" Margin="0,0,8,4" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding HireDate}" Margin="0,0,16,4" />
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="评分：" FontWeight="SemiBold" Margin="0,0,8,4" />
                            <ProgressBar Grid.Row="2" Grid.Column="3" Minimum="1" Maximum="5" Value="{Binding PerformanceRating}" Width="120" />
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="备注：" FontWeight="SemiBold" Margin="0,0,8,4" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding Notes}" TextWrapping="Wrap" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </DataGrid.RowDetailsTemplate>
        </DataGrid>
    </Grid>
</UserControl>
