<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Avalonia.Plugin.Template.ViewModels"
             x:Class="Avalonia.Plugin.Template.Pages.TemplatePage"
             x:DataType="vm:TemplatePageViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450">
    <Grid Margin="16" RowDefinitions="Auto,*">
        
        <StackPanel Grid.Row="0" Spacing="4" Margin="0 0 0 24">
            <TextBlock Text="Template Plugin Demo" Theme="{StaticResource TitleTextBlock}" Classes="H3" />
            <TextBlock Text="A minimal plugin example demonstrating the plugin system" Classes="Secondary" />
        </StackPanel>

        <StackPanel Grid.Row="1" Spacing="24" HorizontalAlignment="Center" VerticalAlignment="Center">
            
            <Border Theme="{DynamicResource CardBorder}" CornerRadius="12" Padding="32" MinWidth="400">
                <StackPanel Spacing="16" HorizontalAlignment="Center">
                    
                    <TextBlock Text="{Binding WelcomeMessage}" Theme="{StaticResource TitleTextBlock}" Classes="H4"
                               HorizontalAlignment="Center" TextAlignment="Center"/>
                    
                    <TextBlock Classes="Tertiary" HorizontalAlignment="Center">
                        <Run Text="Click count: "/><Run Text="{Binding ClickCount}"/>
                    </TextBlock>

                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                        <Button Content="Click Me!" Command="{Binding IncrementCountCommand}"
                                Theme="{DynamicResource SolidButton}" Classes="Primary" MinWidth="120"/>
                        <Button Content="Reset" Command="{Binding ResetCountCommand}"
                                Theme="{DynamicResource SolidButton}" MinWidth="80"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Theme="{DynamicResource CardBorder}" Padding="16">
                <StackPanel Spacing="4">
                    <TextBlock Text="Plugin Info" Classes="SectionTitle" />
                    <TextBlock FontSize="12" Classes="Tertiary" TextWrapping="Wrap">
                        This page is provided by the Template Plugin and loaded dynamically at runtime.
                        The plugin demonstrates ViewModel-View binding, commands, and menu integration.
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
