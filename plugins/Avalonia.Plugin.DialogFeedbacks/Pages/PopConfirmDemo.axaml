<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:u="https://irihi.tech/ursa"
             xmlns:viewModels="clr-namespace:Avalonia.Plugin.DialogFeedbacks.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800"
             d:DesignHeight="450"
             x:DataType="viewModels:PopConfirmDemoViewModel"
             x:Class="Avalonia.Plugin.DialogFeedbacks.Pages.PopConfirmDemo">
    <StackPanel HorizontalAlignment="Left">
        <Border Theme="{DynamicResource CardBorder}">
            <u:Form>
                <u:ControlClassesInput 
                    Name="classInput"
                    u:FormItem.Label="Control Classes"
                    Width="240">
                </u:ControlClassesInput>
                <u:EnumSelector 
                    Name="placement"
                    Width="240"
                    u:FormItem.Label="Popup Placement"
                    EnumType="{x:Type PlacementMode}"
                    Value="{x:Static PlacementMode.BottomEdgeAlignedLeft}" />
            </u:Form>
        </Border>
        <TextBlock Text="{DynamicResource LBL_DefaultPopConfirm}" Margin="0 16" />
        <u:PopConfirm PopupHeader="{DynamicResource POP_ConfirmSaveHeader}"
                      HorizontalAlignment="Left"
                      PopupContent="{DynamicResource POP_IrreversibleChange}"
                      Placement="{Binding #placement.Value}"
                      ConfirmCommand="{Binding ConfirmCommand}"
                      CancelCommand="{Binding Path=CancelCommand}">
            <Button Content="Hello World" />
        </u:PopConfirm>
        <TextBlock Text="{DynamicResource LBL_FocusTriggerMode}" Margin="0 16" />
        <u:PopConfirm PopupHeader="{DynamicResource POP_ConfirmSaveHeader}"
                      PopupContent="{DynamicResource POP_IrreversibleChange}"
                      TriggerMode="Focus, Click"
                      HorizontalAlignment="Left"
                      Placement="{Binding #placement.Value}"
                      u:ControlClassesInput.Source="{Binding #classInput}"
                      ConfirmCommand="{Binding ConfirmCommand}"
                      CancelCommand="{Binding Path=CancelCommand}">
            <Button Content="Hello World" />
        </u:PopConfirm>
        <TextBlock
            Text="{DynamicResource LBL_NonButtonElement}"
            Margin="0 16" />
        <u:PopConfirm PopupHeader="{DynamicResource POP_ConfirmSaveHeader}"
                      PopupContent="{DynamicResource POP_IrreversibleChange}"
                      TriggerMode="Click"
                      HorizontalAlignment="Left"
                      u:ControlClassesInput.Source="{Binding #classInput}"
                      Placement="{Binding #placement.Value}"
                      ConfirmCommand="{Binding ConfirmCommand}"
                      CancelCommand="{Binding Path=CancelCommand}">
            <TextBlock Text="Hello World" />
        </u:PopConfirm>
        <TextBlock Text="{DynamicResource LBL_AsyncCommandSupport}"
                   Margin="0 16" />
        <u:PopConfirm PopupHeader="{DynamicResource POP_ConfirmSaveHeader}"
                      PopupContent="{DynamicResource POP_IrreversibleChange}"
                      HorizontalAlignment="Left"
                      Placement="{Binding #placement.Value}"
                      u:ControlClassesInput.Source="{Binding #classInput}"
                      ConfirmCommand="{Binding AsyncConfirmCommand}"
                      CancelCommand="{Binding Path=AsyncCancelCommand}">
            <Button Content="Hello World" />
        </u:PopConfirm>
    </StackPanel>
</UserControl>
